#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _stage2_common import emit_json, normalize_research_model, read_stdin_json, save_step, utc_now
from _stage2_common import ensure_run_id


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    data = read_stdin_json()
    plan = data.get("campaign_plan", {})
    run_id = ensure_run_id(data.get("run_id", ""), args.brand_slug, plan.get("campaign_name", ""))
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))

    payload = {
        "type": "strategy_review_preview",
        "stub": False,
        "mode": data.get("mode", "fallback"),
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": args.brand_slug,
        "review_packet": {
            "campaign_name": plan.get("campaign_name", ""),
            "objective": plan.get("objective", ""),
            "core_message": plan.get("core_message", ""),
            "channels_in_scope": [item.get("channel", "") for item in plan.get("channel_plans", [])],
            "competitor_name": (plan.get("competitor_context") or {}).get("competitor", ""),
            "competitor_website": (plan.get("competitor_context") or {}).get("competitor_url", ""),
            "competitor_canonical_domain": (plan.get("competitor_context") or {}).get("canonical_domain", ""),
            "competitor_trust_classification": (plan.get("competitor_context") or {}).get("trust_classification", ""),
            "competitor_facebook_page_url": (plan.get("competitor_context") or {}).get("facebook_page_url", ""),
            "competitor_ad_library_url": (plan.get("competitor_context") or {}).get("ad_library_url", ""),
            "competitor_cta_domains": (plan.get("competitor_context") or {}).get("cta_domains", []),
            "competitor_alias_domains": (plan.get("competitor_context") or {}).get("alias_domains", []),
            "competitor_trust_reasons": (plan.get("competitor_context") or {}).get("trust_reasons", []),
        },
        "approval_preview": {
            "status": "pending_human_review",
            "reason": "Stage 2 strategy review remains a human approval step in the Lobster workflow.",
        },
    }
    save_step(run_id, "strategy_review_preview", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
