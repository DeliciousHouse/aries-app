#!/usr/bin/env python3
import argparse
import json
import os
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _stage3_common import (
    emit_json,
    ensure_run_id,
    normalize_research_model,
    read_stdin_json,
    save_artifact_json,
    save_artifact_text,
    save_step,
    slugify,
    utc_now,
)
from _stage4_common import run_veo_render, veo_render_enabled
from _marketing_profile_common import record_or_empty, validate_copy_text, validate_unique_copy_list


PLATFORM_DEFAULTS = [
    {
        "platform": "YouTube Shorts",
        "platform_slug": "youtube-shorts",
        "aspect_ratio": "9:16",
        "target_duration_seconds": 30,
        "max_duration_seconds": 60,
    },
    {
        "platform": "TikTok",
        "platform_slug": "tiktok",
        "aspect_ratio": "9:16",
        "target_duration_seconds": 20,
        "max_duration_seconds": 60,
    },
    {
        "platform": "Instagram Reels",
        "platform_slug": "instagram-reels",
        "aspect_ratio": "9:16",
        "target_duration_seconds": 20,
        "max_duration_seconds": 60,
    },
    {
        "platform": "Instagram Feed video",
        "platform_slug": "instagram-feed-video",
        "aspect_ratio": "4:5",
        "target_duration_seconds": 30,
        "max_duration_seconds": 90,
    },
    {
        "platform": "YouTube longform",
        "platform_slug": "youtube-longform",
        "aspect_ratio": "16:9",
        "target_duration_seconds": 300,
        "max_duration_seconds": 900,
    },
    {
        "platform": "Stories",
        "platform_slug": "stories",
        "aspect_ratio": "9:16",
        "target_duration_seconds": 15,
        "max_duration_seconds": 15,
    },
    {
        "platform": "LinkedIn video",
        "platform_slug": "linkedin-video",
        "aspect_ratio": "1:1",
        "target_duration_seconds": 45,
        "max_duration_seconds": 120,
    },
    {
        "platform": "X video",
        "platform_slug": "x-video",
        "aspect_ratio": "1:1",
        "target_duration_seconds": 30,
        "max_duration_seconds": 140,
    },
]


def first_nonempty(*values, default="") -> str:
    for value in values:
        if isinstance(value, str) and value.strip():
            return value.strip()
    return default


def list_or_empty(value) -> list:
    return value if isinstance(value, list) else []


def derive_campaign_id(brand_slug: str, brief: dict) -> str:
    return slugify(
        first_nonempty(
            brief.get("campaign_id", ""),
            brief.get("campaign_name", ""),
            brief.get("objective", ""),
            brand_slug,
            default="campaign",
        )
    )


def derive_concept_id(brief: dict, script_assets: dict) -> str:
    short_video = script_assets.get("short_video_script", {})
    return slugify(
        first_nonempty(
            short_video.get("concept_id", ""),
            short_video.get("opening_line", ""),
            brief.get("core_message", ""),
            default="video-concept",
        )
    )


def brand_guidelines_from_brief(brief: dict) -> dict:
    design_tokens = record_or_empty(brief.get("design_tokens") or record_or_empty(brief.get("creative_handoff")).get("design_tokens"))
    return {
        "voice_attributes": list_or_empty(brief.get("brand_voice")),
        "proof_points": validate_unique_copy_list("video_contract.proof_points", brief.get("proof_points"), min_items=3, max_items=3, min_tokens=3),
        "primary_cta": validate_copy_text("video_contract.primary_cta", brief.get("primary_cta", ""), min_tokens=2),
        "production_constraints": brief.get("constraints", {}),
        "design_tokens": design_tokens,
        "brand_kit": record_or_empty(brief.get("brand_kit") or record_or_empty(brief.get("creative_handoff")).get("brand_kit")),
    }


def build_story_beats(brief: dict, script_assets: dict) -> list[dict]:
    short_video = record_or_empty(script_assets.get("short_video_script"))
    raw_beats = list_or_empty(short_video.get("beats"))
    if not raw_beats:
        raise SystemExit("quality_gate_failed:video_story_beats:missing")
    total_beats = max(len(raw_beats), 1)
    step = max(int(short_video.get("duration_seconds", 30) / total_beats), 1)
    beats = []
    for index, beat in enumerate(raw_beats, start=1):
        beats.append(
            {
                "sequence": index,
                "label": f"Beat {index}",
                "description": beat,
                "estimated_seconds": step,
            }
        )
    return beats


def build_master_script(brief: dict, script_assets: dict) -> dict:
    short_video = record_or_empty(script_assets.get("short_video_script"))
    meta_ad = record_or_empty(script_assets.get("meta_ad_script"))
    opening_line = validate_copy_text(
        "master_script.opening_line",
        first_nonempty(short_video.get("opening_line", ""), brief.get("core_message", "")),
        min_tokens=3,
    )
    voiceover_lines = [opening_line]
    voiceover_lines.extend(list_or_empty(meta_ad.get("body")))
    return {
        "title": first_nonempty(brief.get("campaign_name", ""), default="Campaign Master Script"),
        "opening_line": opening_line,
        "voiceover_lines": [line for line in voiceover_lines if isinstance(line, str) and line.strip()],
        "story_beats": build_story_beats(brief, script_assets),
        "duration_seconds": short_video.get("duration_seconds", 30),
        "source": "scriptwriter",
    }


def build_render_outputs(base_dir: Path, platform_slug: str) -> dict:
    rendered_dir = base_dir / "rendered" / platform_slug
    return {
        "directory": str(rendered_dir),
        "video_file": str(rendered_dir / f"{platform_slug}.mp4"),
        "captions_file": str(rendered_dir / f"{platform_slug}.srt"),
        "poster_file": str(rendered_dir / f"{platform_slug}.jpg"),
        "project_file": str(rendered_dir / f"{platform_slug}.json"),
    }


def build_platform_contract(
    platform_config: dict,
    master_contract: dict,
    base_dir: Path,
    args: argparse.Namespace,
) -> dict:
    platform_slug = platform_config["platform_slug"]
    target_duration = platform_config["target_duration_seconds"]
    story_beats = master_contract["creative"]["story_beats"]
    return {
        "schema_version": "2026-03-17.video-contract.v1",
        "contract_type": "platform_video_contract",
        "campaign_id": master_contract["campaign_id"],
        "concept_id": master_contract["concept_id"],
        "platform": platform_config["platform"],
        "platform_slug": platform_slug,
        "status": "contract_generated",
        "render_requested": False,
        "render_status": "not_requested",
        "generator": {
            "tool": "veo-video-generator",
            "requested_model": args.video_model,
            "research_model": args.research_model,
            "generated_at": master_contract["generated_at"],
        },
        "inputs": master_contract["inputs"],
        "creative": {
            "summary": master_contract["creative"]["summary"],
            "opening_line": master_contract["creative"]["opening_line"],
            "primary_cta": master_contract["creative"]["primary_cta"],
            "story_beats": story_beats,
            "voiceover_lines": master_contract["creative"]["voiceover_lines"],
        },
        "platform_requirements": {
            "aspect_ratio": platform_config["aspect_ratio"],
            "target_duration_seconds": target_duration,
            "max_duration_seconds": platform_config["max_duration_seconds"],
        },
        "execution": {
            "mode": "contract_generation_only",
            "render_gate": {
                "allowed": False,
                "required_inputs": [
                    "campaign_id",
                    "concept_id",
                    "platform",
                    "contract_path",
                    "render_requested: true",
                ],
                "downstream_only": True,
            },
        },
        "expected_render_outputs": build_render_outputs(base_dir, platform_slug),
    }


def build_brief_markdown(contract: dict) -> str:
    beats = "\n".join(
        f"- {beat['label']}: {beat['description']} ({beat['estimated_seconds']}s est.)"
        for beat in contract["creative"]["story_beats"]
    )
    render_outputs = contract["expected_render_outputs"]
    return "\n".join(
        [
            f"# {contract['platform']} Creative Brief",
            "",
            "## Summary",
            contract["creative"]["summary"],
            "",
            "## Core Direction",
            f"- Opening line: {contract['creative']['opening_line']}",
            f"- CTA: {contract['creative']['primary_cta']}",
            f"- Aspect ratio: {contract['platform_requirements']['aspect_ratio']}",
            f"- Target duration: {contract['platform_requirements']['target_duration_seconds']}s",
            f"- Max duration: {contract['platform_requirements']['max_duration_seconds']}s",
            "",
            "## Story Beats",
            beats,
            "",
            "## Render Status",
            "- Contract generation only.",
            "- render_requested: false",
            "- render_status: not_requested",
            "",
            "## Future Render Outputs",
            f"- Video: {render_outputs['video_file']}",
            f"- Captions: {render_outputs['captions_file']}",
            f"- Poster: {render_outputs['poster_file']}",
            f"- Project: {render_outputs['project_file']}",
        ]
    )


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    parser.add_argument("--video-model", default="veo-3.0-generate-001")
    parser.add_argument("--campaign-id", default="")
    parser.add_argument("--concept-id", default="")
    parser.add_argument("--platform", default="")
    parser.add_argument("--contract-path", default="")
    parser.add_argument("--render-requested", action="store_true")
    args = parser.parse_args()

    data = read_stdin_json()
    script_assets = record_or_empty(data.get("script_assets"))
    brief = record_or_empty(data.get("production_brief"))
    brand_slug = slugify(args.brand_slug or data.get("brand_slug", "client-brand"))
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, brief.get("campaign_name", ""))

    campaign_id = slugify(args.campaign_id or data.get("campaign_id", "") or derive_campaign_id(brand_slug, brief))
    concept_id = slugify(args.concept_id or data.get("concept_id", "") or derive_concept_id(brief, script_assets))
    output_root = Path.cwd() / "output" / "video-contracts" / campaign_id
    briefs_dir = output_root / "briefs"
    output_root.mkdir(parents=True, exist_ok=True)
    briefs_dir.mkdir(parents=True, exist_ok=True)

    render_request = {
        "campaign_id": args.campaign_id,
        "concept_id": args.concept_id,
        "platform": args.platform,
        "contract_path": args.contract_path,
        "render_requested": args.render_requested,
    }
    render_gate_open = all(
        [
            args.render_requested,
            args.campaign_id.strip(),
            args.concept_id.strip(),
            args.platform.strip(),
            args.contract_path.strip(),
        ]
    )

    master_script = build_master_script(brief, script_assets)
    master_contract = {
        "schema_version": "2026-03-17.video-contract.v1",
        "contract_type": "master_video_contract",
        "campaign_id": campaign_id,
        "concept_id": concept_id,
        "brand_slug": brand_slug,
        "generated_at": utc_now(),
        "status": "contract_generated",
        "render_requested": False,
        "render_status": "not_requested",
        "inputs": {
            "approved_campaign_strategy": brief,
            "approved_offer": {
                "summary": validate_copy_text("master_video_contract.offer_summary", brief.get("offer_summary", ""), min_tokens=4),
                "primary_cta": validate_copy_text("master_video_contract.primary_cta", brief.get("primary_cta", ""), min_tokens=2),
            },
            "brand_guidelines": brand_guidelines_from_brief(brief),
            "master_script": master_script,
        },
        "creative": {
            "summary": validate_copy_text("master_video_contract.summary", brief.get("core_message", ""), min_tokens=3),
            "opening_line": master_script["opening_line"],
            "primary_cta": validate_copy_text("master_video_contract.primary_cta", brief.get("primary_cta", ""), min_tokens=2),
            "voiceover_lines": master_script["voiceover_lines"],
            "story_beats": master_script["story_beats"],
        },
        "execution": {
            "mode": "contract_generation_only",
            "render_gate": {
                "allowed": False,
                "required_inputs": [
                    "campaign_id",
                    "concept_id",
                    "platform",
                    "contract_path",
                    "render_requested: true",
                ],
                "downstream_only": True,
            },
            "downstream_render_request_received": render_request,
            "downstream_render_request_valid": render_gate_open,
        },
        "expected_render_outputs": {
            item["platform_slug"]: build_render_outputs(output_root, item["platform_slug"])
            for item in PLATFORM_DEFAULTS
        },
    }

    master_contract_path = output_root / "master-video-contract.json"
    master_contract_path.write_text(json.dumps(master_contract, indent=2, sort_keys=True) + "\n", encoding="utf-8")

    platform_contracts = []
    for platform_config in PLATFORM_DEFAULTS:
        contract = build_platform_contract(platform_config, master_contract, output_root, args)
        contract_path = output_root / f"{platform_config['platform_slug']}.json"
        contract_path.write_text(json.dumps(contract, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        brief_path = briefs_dir / f"{platform_config['platform_slug']}.md"
        brief_path.write_text(build_brief_markdown(contract).rstrip() + "\n", encoding="utf-8")
        platform_contracts.append(
            {
                "platform": platform_config["platform"],
                "platform_slug": platform_config["platform_slug"],
                "contract_path": str(contract_path),
                "brief_path": str(brief_path),
                "expected_render_outputs": contract["expected_render_outputs"],
            }
        )

    platform_index = {
        "schema_version": "2026-03-17.video-contract.v1",
        "campaign_id": campaign_id,
        "concept_id": concept_id,
        "master_contract_path": str(master_contract_path),
        "platforms": platform_contracts,
        "render_gate": {
            "downstream_only": True,
            "required_inputs": [
                "campaign_id",
                "concept_id",
                "platform",
                "contract_path",
                "render_requested: true",
            ],
        },
    }
    platform_index_path = output_root / "platform-index.json"
    platform_index_path.write_text(json.dumps(platform_index, indent=2, sort_keys=True) + "\n", encoding="utf-8")

    # Veo render pass — only runs when LOBSTER_VIDEO_RENDER_ENABLED=1 AND
    # GEMINI_API_KEY is set. Renders TWO videos per aspect ratio (one per
    # family from testing_matrix.video cold/warm funnels), then mirrors each
    # rendered mp4 to all platforms sharing that aspect ratio. Each platform
    # ends up with 2 distinct video variants tagged by family_id.
    # Total Veo calls per campaign with full matrix: 4 (2 families × 2 aspect
    # ratios). Fallback to 2 calls if only one family is available.
    rendered_videos: list[dict] = []
    render_enabled = veo_render_enabled()
    render_mode = "contract_generation_only"
    render_status = "not_requested"
    if render_enabled:
        from _stage4_common import _veo_aspect_to_flag

        render_mode = "contract_and_render"
        render_status = "rendered"

        def _string(value) -> str:
            if isinstance(value, str):
                stripped = value.strip()
                if stripped:
                    return stripped
            return ""

        # Family selection from testing_matrix.video. Prefer 1 cold + 1 warm
        # for funnel variety. Fall back to 2 cold, then 2 warm, then a single
        # default family grounded in master_contract.creative if the matrix
        # is missing entirely (back-compat with older campaigns).
        video_matrix = record_or_empty(brief.get("testing_matrix", {}).get("video", {}) if isinstance(brief, dict) else {})
        raw_cold = [fam for fam in list_or_empty(video_matrix.get("cold_funnel")) if isinstance(fam, dict) and _string(fam.get("primary_hook"))]
        raw_warm = [fam for fam in list_or_empty(video_matrix.get("warm_funnel")) if isinstance(fam, dict) and _string(fam.get("primary_hook"))]
        if raw_cold and raw_warm:
            selected_families = [raw_cold[0], raw_warm[0]]
        elif raw_cold:
            selected_families = raw_cold[:2]
        elif raw_warm:
            selected_families = raw_warm[:2]
        else:
            selected_families = [
                {
                    "family_id": "default",
                    "family_name": "Default",
                    "funnel_stage": "cold",
                    "primary_hook": master_contract["creative"]["opening_line"],
                    "opening_line": master_contract["creative"]["opening_line"],
                    "angle": master_contract["creative"]["summary"],
                    "proof_variants": [],
                    "offer_variants": [],
                }
            ]

        def _build_family_prompt(family: dict) -> str:
            family_name = _string(family.get("family_name")) or _string(family.get("family_id")) or "Default"
            funnel_stage = _string(family.get("funnel_stage")) or "cold"
            hook = _string(family.get("primary_hook")) or master_contract["creative"]["opening_line"]
            opening = _string(family.get("opening_line")) or hook
            angle = _string(family.get("angle")) or master_contract["creative"]["summary"]
            proofs = [p for p in (family.get("proof_variants") or []) if isinstance(p, str) and p.strip()]
            offer_variants = [o for o in (family.get("offer_variants") or []) if isinstance(o, str) and o.strip()]
            offer_line = offer_variants[0] if offer_variants else _string(brief.get("offer_summary"))
            primary_cta = _string(brief.get("primary_cta")) or master_contract["creative"]["primary_cta"]
            lines = [
                f"Create a marketing video for {brand_slug}.",
                f"Family: {family_name} ({funnel_stage})",
                f"Core hook: {hook}",
                f"Opening line: {opening}",
                f"Creative angle: {angle}",
            ]
            if proofs:
                proof_line = ", ".join(proofs[:2])
                lines.append(f"Proof points: {proof_line}")
            if offer_line:
                lines.append(f"Offer emphasis: {offer_line}")
            lines.append(f"Primary call to action at the end: {primary_cta}")
            lines.append("Visual style: polished marketing, brand-forward, on-brand color palette, no text overlays.")
            return "\n".join(lines)

        aspect_groups: dict[str, list[dict]] = {}
        for platform_config in PLATFORM_DEFAULTS:
            bucket_key = _veo_aspect_to_flag(platform_config["aspect_ratio"])
            aspect_groups.setdefault(bucket_key, []).append(platform_config)

        # Build the full (aspect_ratio, family) render job list up front,
        # then dispatch them via ThreadPoolExecutor. Veo 3.x's
        # predictLongRunning endpoint creates a server-side job counted
        # against concurrent render quota — preview models typically allow
        # 2-5 concurrent jobs. Default LOBSTER_VIDEO_PARALLELISM=2 is
        # conservative; tune via env if Google's project quota allows more.
        # run_veo_render already retries 429/503 with exponential backoff, so
        # transient quota overshoot is handled inline.
        render_jobs: list[dict] = []
        for aspect_ratio, platforms in aspect_groups.items():
            representative = platforms[0]
            canonical_slug = representative["platform_slug"]
            canonical_dir = output_root / "rendered" / canonical_slug
            canonical_dir.mkdir(parents=True, exist_ok=True)
            for family_index, family in enumerate(selected_families):
                family_id = slugify(str(family.get("family_id") or f"family-{family_index}"), f"family-{family_index}")
                render_jobs.append(
                    {
                        "aspect_ratio": aspect_ratio,
                        "platforms": platforms,
                        "representative": representative,
                        "canonical_slug": canonical_slug,
                        "canonical_dir": canonical_dir,
                        "family_index": family_index,
                        "family": family,
                        "family_id": family_id,
                        "family_name": _string(family.get("family_name")) or family_id,
                        "funnel_stage": _string(family.get("funnel_stage")) or "cold",
                        "source_video_path": canonical_dir / f"{canonical_slug}-{family_id}.mp4",
                    }
                )

        def _run_render_job(job: dict) -> dict:
            render_result = run_veo_render(
                _build_family_prompt(job["family"]),
                job["source_video_path"],
                job["aspect_ratio"],
                job["representative"].get("target_duration_seconds", 8),
                model=args.video_model,
            )
            return {"job": job, "render_result": render_result}

        video_parallelism_cap = int(os.environ.get("LOBSTER_VIDEO_PARALLELISM", "2") or "2")
        video_parallelism = max(1, min(video_parallelism_cap, len(render_jobs) or 1))

        render_outcomes: list[dict] = []
        first_video_failure: Exception | None = None
        if render_jobs:
            sys.stderr.write(
                f"[veo] dispatching {len(render_jobs)} veo renders with parallelism={video_parallelism}\n"
            )
            sys.stderr.flush()
            with ThreadPoolExecutor(max_workers=video_parallelism) as executor:
                future_to_job = {executor.submit(_run_render_job, job): job for job in render_jobs}
                for future in as_completed(future_to_job):
                    job = future_to_job[future]
                    try:
                        render_outcomes.append(future.result())
                    except Exception as exc:  # noqa: BLE001
                        if first_video_failure is None:
                            first_video_failure = exc
                        sys.stderr.write(
                            f"[veo] render failed aspect={job['aspect_ratio']} family={job['family_id']} error={type(exc).__name__}: {exc}\n"
                        )
                        sys.stderr.flush()
        if first_video_failure is not None:
            raise first_video_failure

        # Post-process: mirror each rendered mp4 to all platforms sharing its
        # aspect ratio, tagged with family_id. Done sequentially after all
        # renders succeed so we never mirror a partial file. Order the
        # outcomes by (aspect_ratio, family_index) so rendered_videos follows
        # the same order as the original nested-loop output — downstream
        # consumers that assumed cold-before-warm ordering still see it.
        render_outcomes.sort(key=lambda o: (o["job"]["aspect_ratio"], o["job"]["family_index"]))
        for outcome in render_outcomes:
            job = outcome["job"]
            render_result = outcome["render_result"]
            family_index = job["family_index"]
            source_bytes = job["source_video_path"].read_bytes()
            mirror_entries: list[dict] = []
            for platform_config in job["platforms"]:
                platform_slug = platform_config["platform_slug"]
                target_dir = output_root / "rendered" / platform_slug
                target_dir.mkdir(parents=True, exist_ok=True)
                tagged_target = target_dir / f"{platform_slug}-{job['family_id']}.mp4"
                if tagged_target != job["source_video_path"]:
                    tagged_target.write_bytes(source_bytes)
                # Back-compat: first family also written to the un-tagged
                # canonical path so older consumers that read
                # `{platform_slug}.mp4` still find a valid mp4.
                if family_index == 0:
                    legacy_target = target_dir / f"{platform_slug}.mp4"
                    if legacy_target != job["source_video_path"]:
                        legacy_target.write_bytes(source_bytes)
                mirror_entries.append(
                    {
                        "platform": platform_config["platform"],
                        "platform_slug": platform_slug,
                        "aspect_ratio": job["aspect_ratio"],
                        "family_id": job["family_id"],
                        "video_path": str(tagged_target),
                        "source_video_path": str(job["source_video_path"]),
                        "duration_seconds": platform_config.get("target_duration_seconds"),
                    }
                )
            rendered_videos.append(
                {
                    "aspect_ratio": job["aspect_ratio"],
                    "family_id": job["family_id"],
                    "family_name": job["family_name"],
                    "funnel_stage": job["funnel_stage"],
                    "canonical_platform_slug": job["canonical_slug"],
                    "source_video_path": str(job["source_video_path"]),
                    "render_result": render_result,
                    "platforms": mirror_entries,
                }
            )

        # Attach all rendered variants to each platform_contract so
        # downstream consumers see both `rendered_video_path` (legacy, first
        # family) and `rendered_video_paths_by_family` (new, all families).
        for platform_contract in platform_contracts:
            target_slug = platform_contract["platform_slug"]
            variants: dict[str, str] = {}
            ordered_variants: list[dict] = []
            for bucket in rendered_videos:
                for item in bucket["platforms"]:
                    if item["platform_slug"] == target_slug:
                        variants[item["family_id"]] = item["video_path"]
                        ordered_variants.append(
                            {
                                "family_id": item["family_id"],
                                "aspect_ratio": item["aspect_ratio"],
                                "video_path": item["video_path"],
                                "source_video_path": item["source_video_path"],
                            }
                        )
            if variants:
                platform_contract["render_status"] = "rendered"
                platform_contract["rendered_video_path"] = ordered_variants[0]["video_path"]
                platform_contract["rendered_video_paths_by_family"] = variants
                platform_contract["rendered_video_variants"] = ordered_variants

    summary_text = "\n".join(
        [
            f"Campaign ID: {campaign_id}",
            f"Concept ID: {concept_id}",
            f"Mode: {render_mode}",
            f"Render status: {render_status}",
            f"Rendered videos: {sum(len(bucket['platforms']) for bucket in rendered_videos)}",
            "Generated contracts:",
            *[f"- {item['contract_path']}" for item in platform_contracts],
        ]
    )
    summary_path = save_artifact_text(run_id, "veo-video-generator/video-contract-summary.txt", summary_text)
    cache_master_path = save_artifact_json(run_id, "veo-video-generator/master-video-contract.json", master_contract)
    cache_index_path = save_artifact_json(run_id, "veo-video-generator/platform-index.json", platform_index)

    payload = {
        "type": "veo_video_generator",
        "stub": False,
        "mode": render_mode,
        "generated_at": master_contract["generated_at"],
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": brand_slug,
        "campaign_id": campaign_id,
        "concept_id": concept_id,
        "production_brief": brief,
        "script_assets": script_assets,
        "video_assets": {
            "master_video_contract": master_contract,
            "platform_index": platform_index,
            "platform_contracts": platform_contracts,
            "render_requested": render_enabled,
            "render_status": render_status,
            "rendered_videos": rendered_videos,
        },
        "handoff": {
            "type": "video_contract_handoff",
            "campaign_id": campaign_id,
            "concept_id": concept_id,
            "output_root": str(output_root),
            "master_video_contract_path": str(master_contract_path),
            "platform_index_path": str(platform_index_path),
            "platform_contract_paths": [item["contract_path"] for item in platform_contracts],
            "brief_paths": [item["brief_path"] for item in platform_contracts],
        },
        "render_gate": {
            "contract_generation_only": True,
            "downstream_render_request_received": render_request,
            "downstream_render_request_valid": render_gate_open,
            "required_inputs": [
                "campaign_id",
                "concept_id",
                "platform",
                "contract_path",
                "render_requested: true",
            ],
        },
        "artifacts": {
            "summary_path": summary_path,
            "cache_master_contract_path": cache_master_path,
            "cache_platform_index_path": cache_index_path,
            "output_root": str(output_root),
        },
    }
    save_step(run_id, "veo_video_generator", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
