#!/usr/bin/env python3
import argparse
import json
import subprocess
import sys
import tempfile
from pathlib import Path


def run_json(command: list[str], stdin_path: Path | None = None, cwd: Path | None = None) -> dict:
    proc = subprocess.run(
        command,
        input=(stdin_path.read_text(encoding="utf-8") if stdin_path else None),
        text=True,
        capture_output=True,
        check=False,
        cwd=cwd,
    )
    if proc.returncode != 0:
        sys.stderr.write(proc.stderr)
        raise SystemExit(proc.returncode)
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"compat runner received non-JSON stdout from {' '.join(command)}: {exc}") from exc


def tsx_command(repo_root: Path) -> list[str]:
    local_tsx = repo_root / "node_modules" / ".bin" / "tsx"
    if local_tsx.exists():
        return [str(local_tsx)]
    return ["npx", "tsx"]


def pybin(script_path: Path) -> list[str]:
    return [sys.executable, str(script_path)]


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--competitor", default="")
    parser.add_argument("--competitor-facebook-url", default="")
    parser.add_argument("--website-url", default="")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--launch-approved", default="false")
    parser.add_argument("--notify-chat", default="true")
    args = parser.parse_args()

    bin_dir = Path(__file__).resolve().parent
    workflow_root = bin_dir.parent
    repo_root = workflow_root.parent

    with tempfile.TemporaryDirectory(prefix="marketing-pipeline-compat-") as tmpdir:
        tmp = Path(tmpdir)

        stage1 = run_json(
            [
                *pybin(bin_dir / "meta-ads-extractor"),
                "--json",
                "--competitor",
                args.competitor,
                "--competitor-facebook-url",
                args.competitor_facebook_url,
                "--strict-mode",
                "true",
            ],
            cwd=workflow_root,
        )
        (tmp / "01-stage1-extract.json").write_text(json.dumps(stage1), encoding="utf-8")

        stage1_analysis = run_json([*pybin(bin_dir / "meta-ads-analyser"), "--json"], tmp / "01-stage1-extract.json", cwd=workflow_root)
        (tmp / "02-stage1-analysis.json").write_text(json.dumps(stage1_analysis), encoding="utf-8")

        stage1_creative = run_json([*pybin(bin_dir / "ad-creative-analysis"), "--json"], tmp / "02-stage1-analysis.json", cwd=workflow_root)
        (tmp / "03-stage1-creative.json").write_text(json.dumps(stage1_creative), encoding="utf-8")

        stage1_final = run_json([*pybin(bin_dir / "ads-analyst"), "--json", "--mode", "compile"], tmp / "03-stage1-creative.json", cwd=workflow_root)
        (tmp / "04-stage1-final.json").write_text(json.dumps(stage1_final), encoding="utf-8")

        stage2_brand_kit = run_json(
            [
                *tsx_command(repo_root),
                str(bin_dir / "brand-kit-bootstrap.ts"),
                "--tenant-id",
                args.brand_slug,
                "--brand-url",
                args.website_url,
            ],
            cwd=workflow_root,
        )
        (tmp / "05-stage2-brand-kit.json").write_text(json.dumps(stage2_brand_kit), encoding="utf-8")

        stage2_brand = run_json(
            [
                *pybin(bin_dir / "website-brand-analysis"),
                "--json",
                "--website-url",
                args.website_url,
                "--brand-slug",
                args.brand_slug,
            ],
            tmp / "04-stage1-final.json",
            cwd=workflow_root,
        )
        (tmp / "06-stage2-brand.json").write_text(json.dumps(stage2_brand), encoding="utf-8")

        stage2_profile = run_json(
            [*pybin(bin_dir / "brand-profile-db-contract"), "--json", "--brand-slug", args.brand_slug],
            tmp / "06-stage2-brand.json",
            cwd=workflow_root,
        )
        (tmp / "07-stage2-profile.json").write_text(json.dumps(stage2_profile), encoding="utf-8")

        stage2_plan = run_json(
            [*pybin(bin_dir / "campaign-planner"), "--json", "--brand-slug", args.brand_slug],
            tmp / "07-stage2-profile.json",
            cwd=workflow_root,
        )
        (tmp / "08-stage2-plan.json").write_text(json.dumps(stage2_plan), encoding="utf-8")

        stage2_review = run_json(
            [*pybin(bin_dir / "strategy-review-preview"), "--json", "--brand-slug", args.brand_slug],
            tmp / "08-stage2-plan.json",
            cwd=workflow_root,
        )
        (tmp / "09-stage2-review.json").write_text(json.dumps(stage2_review), encoding="utf-8")

        stage2_final = run_json(
            [*pybin(bin_dir / "head-of-marketing"), "--json", "--mode", "finalize", "--brand-slug", args.brand_slug],
            tmp / "08-stage2-plan.json",
            cwd=workflow_root,
        )
        (tmp / "10-stage2-final.json").write_text(json.dumps(stage2_final), encoding="utf-8")

        stage3_preflight = run_json(
            [*pybin(bin_dir / "creative-director"), "--json", "--mode", "preflight", "--brand-slug", args.brand_slug],
            tmp / "10-stage2-final.json",
            cwd=workflow_root,
        )
        (tmp / "11-stage3-preflight.json").write_text(json.dumps(stage3_preflight), encoding="utf-8")

        stage3_page = run_json([*pybin(bin_dir / "page-designer"), "--json", "--brand-slug", args.brand_slug], tmp / "11-stage3-preflight.json", cwd=workflow_root)
        (tmp / "12-stage3-page.json").write_text(json.dumps(stage3_page), encoding="utf-8")

        stage3_script = run_json([*pybin(bin_dir / "scriptwriter"), "--json", "--brand-slug", args.brand_slug], tmp / "11-stage3-preflight.json", cwd=workflow_root)
        (tmp / "13-stage3-script.json").write_text(json.dumps(stage3_script), encoding="utf-8")

        stage3_ad = run_json([*pybin(bin_dir / "ad-designer"), "--json", "--brand-slug", args.brand_slug], tmp / "13-stage3-script.json", cwd=workflow_root)
        (tmp / "14-stage3-ad.json").write_text(json.dumps(stage3_ad), encoding="utf-8")

        stage3_video = run_json([*pybin(bin_dir / "veo-video-generator"), "--json", "--brand-slug", args.brand_slug], tmp / "14-stage3-ad.json", cwd=workflow_root)
        (tmp / "15-stage3-video.json").write_text(json.dumps(stage3_video), encoding="utf-8")

        stage3_review = run_json([*pybin(bin_dir / "production-review-preview"), "--json", "--brand-slug", args.brand_slug], tmp / "15-stage3-video.json", cwd=workflow_root)
        (tmp / "16-stage3-review.json").write_text(json.dumps(stage3_review), encoding="utf-8")

        stage3_final = run_json(
            [*pybin(bin_dir / "creative-director"), "--json", "--mode", "finalize", "--brand-slug", args.brand_slug],
            tmp / "16-stage3-review.json",
            cwd=workflow_root,
        )
        (tmp / "17-stage3-final.json").write_text(json.dumps(stage3_final), encoding="utf-8")

        stage4_preflight = run_json(
            [*pybin(bin_dir / "performance-marketer"), "--json", "--mode", "preflight", "--brand-slug", args.brand_slug],
            tmp / "17-stage3-final.json",
            cwd=workflow_root,
        )
        (tmp / "18-stage4-preflight.json").write_text(json.dumps(stage4_preflight), encoding="utf-8")

        stage4_review = run_json(
            [
                *pybin(bin_dir / "launch-review-preview"),
                "--json",
                "--brand-slug",
                args.brand_slug,
                "--launch-approved",
                args.launch_approved,
                "--notify-chat",
                args.notify_chat,
            ],
            tmp / "18-stage4-preflight.json",
            cwd=workflow_root,
        )
        stage4_review["compatibility_mode"] = "marketing-pipeline-compat"
        stage4_review["runner_chain"] = [
            "meta-ads-extractor",
            "meta-ads-analyser",
            "ad-creative-analysis",
            "ads-analyst --mode compile",
            "brand-kit-bootstrap.ts",
            "website-brand-analysis",
            "brand-profile-db-contract",
            "campaign-planner",
            "strategy-review-preview",
            "head-of-marketing --mode finalize",
            "creative-director --mode preflight",
            "page-designer",
            "scriptwriter",
            "ad-designer",
            "veo-video-generator",
            "production-review-preview",
            "creative-director --mode finalize",
            "performance-marketer --mode preflight",
            "launch-review-preview",
        ]

        json.dump(stage4_review, sys.stdout, indent=2, sort_keys=True)
        sys.stdout.write("\n")
        return 0


if __name__ == "__main__":
    raise SystemExit(main())
