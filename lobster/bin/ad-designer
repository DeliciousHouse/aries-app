#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _stage3_common import emit_json, ensure_run_id, normalize_research_model, read_stdin_json, save_artifact_text, save_step, slugify, utc_now
from _stage4_common import render_static_publish_asset
from _canonical_outputs import brand_output_paths, write_text
from _marketing_profile_common import record_or_empty, validate_copy_text, validate_unique_copy_list


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    data = read_stdin_json()
    script_assets = record_or_empty(data.get("script_assets"))
    brief = record_or_empty(data.get("production_brief"))
    brand_slug = slugify(args.brand_slug or data.get("brand_slug", "client-brand"))
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, brief.get("campaign_name", ""))
    hook = validate_copy_text("ad_designer.hook", record_or_empty(script_assets.get("meta_ad_script")).get("hook") or brief.get("core_message"), min_tokens=3)
    cta = validate_copy_text("ad_designer.cta", brief.get("primary_cta"), min_tokens=2)
    proof_points = validate_unique_copy_list("ad_designer.proof_points", brief.get("proof_points"), min_items=3, max_items=3, min_tokens=3)
    design_tokens = record_or_empty(brief.get("design_tokens") or record_or_empty(brief.get("creative_handoff")).get("design_tokens"))
    palette = record_or_empty(design_tokens.get("palette"))
    typography = record_or_empty(design_tokens.get("typography"))

    ad_assets = {
        "creative_brief": {
            "primary_hook": hook,
            "concepts": [
                {
                    "name": "Proof Card",
                    "format": "static",
                    "headline": hook,
                    "body": record_or_empty(script_assets.get("meta_ad_script")).get("body", []),
                },
                {
                    "name": "Problem / Solution Reel",
                    "format": "short-video",
                    "headline": hook,
                    "body": record_or_empty(script_assets.get("short_video_script")).get("beats", []),
                },
            ],
            "design_system": {
                "typography": typography,
                "color_direction": palette,
                "cta_lockup": cta,
            },
        },
        "asset_specs": [
            {"placement": "meta_feed", "size": "1080x1350", "format": "png or mp4"},
            {"placement": "meta_story", "size": "1080x1920", "format": "png or mp4"},
        ],
    }

    spec_text = "\n".join(
        [
            f"Primary hook: {hook}",
            f"CTA: {cta}",
            "Placements:",
            *[f"- {item['placement']}: {item['size']} ({item['format']})" for item in ad_assets["asset_specs"]],
        ]
    )
    spec_path = save_artifact_text(run_id, "ad-designer/ad-specs.txt", spec_text)
    paths = brand_output_paths(brand_slug)
    ad_images_dir = paths["ad_images_dir"]
    spec_md_path = write_text(ad_images_dir / "ad-specs.md", spec_text)
    meta_feed_contract = {
        "platform": "Meta Feed",
        "creative": {
            "headline": hook,
            "body_lines": record_or_empty(script_assets.get("meta_ad_script")).get("body", []),
            "proof_points": proof_points,
            "primary_cta": cta,
        },
        "layout": {
            "aspect_ratio": "4:5",
        },
        "brand_tokens": design_tokens,
    }
    story_contract = {
        "platform": "Meta Story",
        "creative": {
            "headline": hook,
            "body_lines": record_or_empty(script_assets.get("short_video_script")).get("beats", []),
            "proof_points": proof_points,
            "primary_cta": cta,
        },
        "layout": {
            "aspect_ratio": "9:16",
        },
        "brand_tokens": design_tokens,
    }
    meta_feed_asset = render_static_publish_asset(meta_feed_contract, ad_images_dir, "meta-feed")
    meta_story_asset = render_static_publish_asset(story_contract, ad_images_dir, "meta-story")

    payload = {
        "type": "ad_designer",
        "stub": False,
        "mode": "live",
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": brand_slug,
        "production_brief": brief,
        "script_assets": script_assets,
        "ad_assets": ad_assets,
        "artifacts": {
            "spec_path": spec_path,
            "canonical_spec_path": spec_md_path,
            "meta_feed_image_path": meta_feed_asset["image_path"],
            "meta_story_image_path": meta_story_asset["image_path"],
            "meta_feed_image_generation": meta_feed_asset["nano_banana"],
            "meta_story_image_generation": meta_story_asset["nano_banana"],
            "honesty_note": "This local wrapper outputs creative specs and production-ready draft images in canonical artifact paths; final platform publish still belongs to stage 4.",
            "design_tokens": design_tokens,
        },
    }
    save_step(run_id, "ad_designer", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
