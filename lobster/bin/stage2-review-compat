#!/usr/bin/env python3
import argparse
import base64
import json
import sys
from datetime import datetime, timezone


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def decode_payload(value: str) -> dict:
    if not value.strip():
        return {}
    return json.loads(base64.b64decode(value).decode("utf-8"))


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-url", default="")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--stage1-summary-base64", default="")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    stage1_summary = decode_payload(args.stage1_summary_base64)
    payload = {
        "type": "strategy_review_preview",
        "stub": False,
        "mode": "compat",
        "generated_at": utc_now(),
        "run_id": f"stage2-review-{args.brand_slug}",
        "brand_slug": args.brand_slug,
        "brand_url": args.brand_url or None,
        "research_model": args.research_model,
        "stage1_summary": stage1_summary,
        "review_packet": {
            "campaign_name": f"{args.brand_slug} brand review",
            "objective": "Review the synthesized brand direction before strategy finalization.",
            "channels_in_scope": ["meta-ads", "landing-page", "video"],
        },
    }
    json.dump(payload, sys.stdout, indent=2, sort_keys=True)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
