#!/usr/bin/env python3
import argparse
import base64
import json
import sys
from datetime import datetime, timezone


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def decode_payload(value: str) -> dict:
    if not value.strip():
        return {}
    return json.loads(base64.b64decode(value).decode("utf-8"))


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--strategy-handoff-base64", default="")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    strategy_handoff = decode_payload(args.strategy_handoff_base64).get("strategy_handoff", {})
    payload = {
        "type": "production_review_preview",
        "stub": False,
        "mode": "compat",
        "generated_at": utc_now(),
        "run_id": f"stage3-review-{args.brand_slug}",
        "brand_slug": args.brand_slug,
        "research_model": args.research_model,
        "strategy_handoff": strategy_handoff,
        "review_packet": {
            "campaign_name": strategy_handoff.get("campaign_name") or f"{args.brand_slug} production review",
            "summary": "Creative production is ready for review.",
        },
    }
    json.dump(payload, sys.stdout, indent=2, sort_keys=True)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
