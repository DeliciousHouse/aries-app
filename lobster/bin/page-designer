#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _marketing_profile_common import (
    record_or_empty,
    validate_copy_text,
    validate_unique_copy_list,
)
from _stage3_common import emit_json, ensure_run_id, normalize_research_model, read_stdin_json, save_artifact_text, save_step, slugify, utc_now
from _canonical_outputs import brand_output_paths, write_text


def _token(value: dict, *path: str, default: str = "") -> str:
    current = value
    for key in path:
        if not isinstance(current, dict):
            return default
        current = current.get(key)
    return current if isinstance(current, str) and current.strip() else default


def _require_token(value: dict, *path: str) -> str:
    token = _token(value, *path, default="")
    if not token:
        raise RuntimeError(f"quality_gate_failed:page_design_tokens_missing:{'.'.join(path)}")
    return token


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    data = read_stdin_json()
    brief = record_or_empty(data.get("production_brief"))
    creative_handoff = record_or_empty(brief.get("creative_handoff"))
    hooks = record_or_empty(creative_handoff.get("hooks"))
    opening_lines = record_or_empty(creative_handoff.get("opening_lines"))
    landing_hooks = hooks.get("landing-page") if isinstance(hooks.get("landing-page"), list) else []
    landing_opening_lines = opening_lines.get("landing-page") if isinstance(opening_lines.get("landing-page"), list) else []
    brand_slug = slugify(args.brand_slug or data.get("brand_slug", "client-brand"))
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, brief.get("campaign_name", ""))
    proof_points = validate_unique_copy_list("page.proof_points", brief.get("proof_points"), min_items=3, max_items=3, min_tokens=3)
    primary_cta = validate_copy_text("page.primary_cta", brief.get("primary_cta"), min_tokens=2)
    hero_headline = validate_copy_text("page.hero_headline", landing_hooks[0] if landing_hooks else brief.get("core_message"), min_tokens=3)
    hero_subheadline = validate_copy_text("page.hero_subheadline", landing_opening_lines[0] if landing_opening_lines else brief.get("offer_summary"), min_tokens=4)
    problem_statement = validate_copy_text("page.problem_statement", brief.get("problem_statement"), min_tokens=4)
    design_tokens = record_or_empty(brief.get("design_tokens") or creative_handoff.get("design_tokens"))
    theme_mode = _require_token(design_tokens, "palette", "theme_mode")
    background = _require_token(design_tokens, "palette", "background")
    _require_token(design_tokens, "palette", "surface")
    _require_token(design_tokens, "palette", "text")
    _require_token(design_tokens, "palette", "accent")
    _require_token(design_tokens, "palette", "accent_contrast")
    _require_token(design_tokens, "palette", "outline")
    _require_token(design_tokens, "palette", "muted")
    _require_token(design_tokens, "typography", "display_stack")
    _require_token(design_tokens, "typography", "body_stack")

    page_assets = {
        "landing_page": {
            "slug": f"/{brand_slug}/campaign",
            "hero_headline": hero_headline,
            "hero_subheadline": hero_subheadline,
            "problem_statement": problem_statement,
            "primary_cta": primary_cta,
            "sections": [
                "Hero with differentiated promise and direct CTA",
                "Problem and stakes section grounded in the buyer pain",
                "Proof section with concrete credibility and outcomes",
                "Offer detail section that resolves the next-step friction",
            ],
            "message_match_checks": [
                "Landing headline matches the paid-social hook.",
                "Primary CTA remains identical across page, ad, and video.",
                "Proof appears before the longer offer explanation.",
            ],
        },
        "page_asset_recommendations": [
            {
                "asset_type": "hero_visual",
                "direction": "Use a premium editorial visual that supports the promise without competing with the headline.",
            },
            {
                "asset_type": "proof_strip",
                "direction": "Support the promise with quantified proof and customer credibility immediately below the fold.",
            },
        ],
        "proof_points": proof_points,
        "design_tokens": design_tokens,
        "design_token_source": "validated_brand_kit",
    }

    preview_text = "\n".join(
        [
            f"Campaign: {brief.get('campaign_name', '')}",
            f"Headline: {hero_headline}",
            f"Subheadline: {hero_subheadline}",
            f"Problem statement: {problem_statement}",
            f"CTA: {primary_cta}",
            "Proof points:",
            *[f"- {item}" for item in proof_points],
        ]
    )
    preview_path = save_artifact_text(run_id, "page-designer/landing-page-preview.txt", preview_text)
    paths = brand_output_paths(brand_slug)
    landing_dir = paths["landing_pages_dir"]
    landing_html = "".join(
        [
            "<!doctype html><html><head><meta charset='utf-8' />",
            f"<title>{brief.get('campaign_name', brand_slug)}</title>",
            f"<meta name='theme-color' content='{background}' />",
            f"<link rel='stylesheet' href='../../{brand_slug}-design-system.css' />",
            "<style>",
            f"html{{color-scheme:{theme_mode};}}",
            "body{max-width:960px;margin:0 auto;padding:48px;background:var(--brand-bg);color:var(--brand-text);font-family:var(--font-body);}",
            "h1,h2{font-family:var(--font-display);}",
            ".cta{display:inline-block;padding:14px 22px;background:var(--brand-accent);color:var(--brand-accent-contrast);border-radius:999px;font-weight:700;text-decoration:none;}",
            "section{margin:28px 0;}",
            ".card{padding:24px;border:1px solid var(--brand-outline);border-radius:20px;background:var(--brand-surface);}",
            ".lede{color:var(--brand-muted);}",
            "</style>",
            f"</head><body data-brand-theme='{theme_mode}' data-design-token-source='validated_brand_kit'>",
            f"<section class='card'><h1>{hero_headline}</h1><p class='lede'>{hero_subheadline}</p><p>{problem_statement}</p><a class='cta' href='#cta'>{primary_cta}</a></section>",
            "<section class='card'><h2>Proof</h2><ul>",
            *[f"<li>{item}</li>" for item in proof_points],
            "</ul></section>",
            f"<section id='cta' class='card'><h2>Next Step</h2><p>{brief.get('offer_summary', '')}</p><a class='cta' href='#'>{primary_cta}</a></section>",
            "</body></html>",
        ]
    )
    landing_page_path = write_text(landing_dir / "index.html", landing_html)

    payload = {
        "type": "page_designer",
        "stub": False,
        "mode": "live",
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": brand_slug,
        "production_brief": brief,
        "page_assets": page_assets,
        "artifacts": {
            "preview_path": preview_path,
            "landing_page_path": landing_page_path,
            "honesty_note": "This local wrapper generates page recommendations and copy structure only; no page is rendered or deployed.",
            "design_token_source": "validated_brand_kit",
        },
    }
    save_step(run_id, "page_designer", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
