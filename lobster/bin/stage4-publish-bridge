#!/usr/bin/env python3
import argparse
import json
import subprocess
import sys
import tempfile
from pathlib import Path


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--launch-approved", default="false")
    parser.add_argument("--notify-chat", default="true")
    args = parser.parse_args()

    raw = sys.stdin.read().strip()
    if not raw:
        raise SystemExit("stage4-publish-bridge expected production handoff JSON on stdin")
    try:
        json.loads(raw)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON on stdin: {exc}") from exc

    workflow = Path(__file__).resolve().parent.parent / "stage-4-publish-optimize" / "workflow.lobster"
    with tempfile.NamedTemporaryFile(mode="w", encoding="utf-8", suffix=".json", prefix="lobster-stage4-handoff-", delete=False) as handle:
        handle.write(raw)
        handoff_path = handle.name
    payload = {
        "brand_slug": args.brand_slug,
        "production_handoff_path": handoff_path,
    }
    launch_approved = args.launch_approved.strip().lower() in {"1", "true", "yes", "y", "on"}
    notify_chat = args.notify_chat.strip().lower() in {"1", "true", "yes", "y", "on"}
    try:
        if not launch_approved:
            proc = subprocess.run(
                [
                    "./bin/performance-marketer",
                    "--json",
                    "--mode",
                    "preflight",
                    "--brand-slug",
                    args.brand_slug,
                    "--production-handoff-path",
                    handoff_path,
                ],
                text=True,
                capture_output=True,
                check=False,
            )
            if proc.returncode != 0:
                sys.stdout.write(proc.stdout)
                sys.stderr.write(proc.stderr)
                return proc.returncode
            preview_proc = subprocess.run(
                [
                    "./bin/launch-review-preview",
                    "--json",
                    "--brand-slug",
                    args.brand_slug,
                    "--launch-approved",
                    "false",
                    "--notify-chat",
                    "true" if notify_chat else "false",
                ],
                input=proc.stdout,
                text=True,
                capture_output=True,
                check=False,
            )
            sys.stdout.write(preview_proc.stdout)
            sys.stderr.write(preview_proc.stderr)
            return preview_proc.returncode
        proc = subprocess.run(
            ["./bin/stage4-publish-compat", "--json", "--brand-slug", args.brand_slug, "--production-handoff-path", handoff_path],
            text=True,
            capture_output=True,
            check=False,
        )
        sys.stdout.write(proc.stdout)
        sys.stderr.write(proc.stderr)
        return proc.returncode
    finally:
        try:
            Path(handoff_path).unlink(missing_ok=True)
        except Exception:
            pass


if __name__ == "__main__":
    raise SystemExit(main())
