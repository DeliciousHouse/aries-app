#!/usr/bin/env python3
import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _stage4_common import emit_json, ensure_run_id, openclaw_system_event, read_stdin_json, save_artifact_text, save_step, slugify, utc_now


def _as_bool(value: str) -> bool:
    return (value or "").strip().lower() in {"1", "true", "yes", "y", "on"}


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--launch-approved", default="false")
    parser.add_argument("--notify-chat", default="true")
    args = parser.parse_args()

    data = read_stdin_json()
    brand_slug = slugify(args.brand_slug or data.get("brand_slug", "client-brand"))
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, data.get("campaign_name", ""))
    plan = data.get("publish_plan", {})
    launch_approved = _as_bool(args.launch_approved)
    preview = "\n".join(
        [
            f"Campaign: {data.get('campaign_name', '')}",
            f"Static contracts: {plan.get('static_contract_count', 0)}",
            f"Video contracts: {plan.get('video_contract_count', 0)}",
            f"Approval state: {'approved' if launch_approved else 'pending_human_review'}",
            "Launch review remains a human approval gate.",
        ]
    )
    preview_path = save_artifact_text(run_id, "launch-review-preview/preview.txt", preview)
    approval_message = (
        f"Approval needed: marketing pipeline launch review for {data.get('campaign_name', brand_slug)}. "
        f"Static assets: {plan.get('static_contract_count', 0)}. Video assets: {plan.get('video_contract_count', 0)}. "
        "Reply with approval and rerun with launch_approved=true to generate publish-ready assets."
    )
    notification = {
        "executed": False,
        "status": "skipped",
        "stdout": "",
        "stderr": "",
        "returncode": None,
    }
    if (not launch_approved) and _as_bool(args.notify_chat):
        notification = openclaw_system_event(approval_message, mode="now")
    payload = {
        "type": "launch_review_preview",
        "mode": "compiled",
        "generated_at": utc_now(),
        "run_id": run_id,
        "brand_slug": brand_slug,
        "approval_preview": {
            "status": "approved" if launch_approved else "pending_human_review",
            "reason": "Stage 4 launch review remains a human approval step in the Lobster workflow.",
            "message": approval_message,
        },
        "artifacts": {
            "preview_path": preview_path,
        },
        "chat_notification": notification,
    }
    save_step(run_id, "launch_review_preview", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
