#!/usr/bin/env python3
import argparse
import json
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _stage4_common import emit_json, ensure_run_id, openclaw_system_event, read_stdin_json, save_artifact_text, save_step, slugify, utc_now
from _marketing_profile_common import validate_copy_text, validate_unique_copy_list


def _as_bool(value: str) -> bool:
    return (value or "").strip().lower() in {"1", "true", "yes", "y", "on"}


def _as_dict(value):
    return value if isinstance(value, dict) else {}


def _as_list(value):
    return value if isinstance(value, list) else []


def _as_str(value, default: str = "") -> str:
    if isinstance(value, str) and value.strip():
        return value.strip()
    if isinstance(value, (int, float, bool)):
        return str(value)
    return default


def _read_json_file(path_value: str) -> dict:
    if not path_value:
        return {}
    candidate = Path(path_value)
    if not candidate.exists() or not candidate.is_file():
        return {}
    try:
        return json.loads(candidate.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _existing_file_paths(paths: list[str]) -> list[str]:
    existing: list[str] = []
    seen: set[str] = set()
    for path_value in paths:
        normalized = _as_str(path_value)
        if not normalized:
            continue
        candidate = Path(normalized)
        if candidate.exists() and candidate.is_file():
            resolved = str(candidate)
            if resolved in seen:
                continue
            seen.add(resolved)
            existing.append(resolved)
    return existing


STATIC_PREVIEW_SUFFIXES = {".png", ".jpg", ".jpeg", ".webp", ".gif", ".svg", ".html"}
VIDEO_PREVIEW_SUFFIXES = {".png", ".jpg", ".jpeg", ".webp", ".gif", ".mp4", ".mov", ".webm", ".m4v"}


def _existing_preview_media_paths(paths: list[str], allowed_suffixes: set[str]) -> list[str]:
    existing: list[str] = []
    seen: set[str] = set()
    for path_value in paths:
        normalized = _as_str(path_value)
        if not normalized:
            continue
        candidate = Path(normalized)
        if not candidate.exists() or not candidate.is_file():
            continue
        if candidate.suffix.lower() not in allowed_suffixes:
            continue
        resolved = str(candidate)
        if resolved in seen:
            continue
        seen.add(resolved)
        existing.append(resolved)
    return existing


def _preview_state(actual_media_paths: list[str]) -> str:
    return "generated_preview" if actual_media_paths else "contract_only"


CAMPAIGN_WINDOW_DAYS = 30
CAMPAIGN_COLD_WINDOW_DAYS = 14  # cold/TOFU content lands in weeks 1-2
CAMPAIGN_POST_HOUR_UTC = 14     # 14:00 UTC default posting time


def _iso_z(dt) -> str:
    """Serialize a datetime as the UTC Z-suffix format the UI expects."""
    return dt.strftime("%Y-%m-%dT%H:%M:%S.000Z")


def _schedule_event_time(start_day_dt, day_offset: int):
    return start_day_dt.replace(hour=CAMPAIGN_POST_HOUR_UTC, minute=0, second=0, microsecond=0) + timedelta(days=day_offset)


def _funnel_weighted_offsets(count: int, window_days: int) -> list[int]:
    """Return day offsets for `count` events spread evenly across `window_days`.
    Uses the open-interval midpoint spacing so events avoid day 0 and the final day."""
    if count <= 0 or window_days <= 0:
        return []
    step = window_days / (count + 1)
    offsets = [min(window_days - 1, max(0, round(step * (index + 1)))) for index in range(count)]
    # Deduplicate while preserving order; pad by nudging forward when two events land on the same day.
    used: set[int] = set()
    result: list[int] = []
    for offset in offsets:
        actual = offset
        while actual in used and actual < window_days:
            actual += 1
        used.add(actual)
        result.append(min(actual, window_days - 1))
    return result


def _build_content_calendar(platform_previews: list[dict], approved_at) -> dict:
    """Distribute platform_previews across a 30-day funnel-weighted campaign window.

    - Cold / TOFU previews get scheduled in days 0..CAMPAIGN_COLD_WINDOW_DAYS
    - Warm / MOFU / BOFU previews get scheduled in days CAMPAIGN_COLD_WINDOW_DAYS..CAMPAIGN_WINDOW_DAYS
    - Within each bucket, events are spread evenly at CAMPAIGN_POST_HOUR_UTC
    """
    start_of_day = approved_at.replace(hour=0, minute=0, second=0, microsecond=0)
    cold_previews: list[dict] = []
    warm_previews: list[dict] = []
    for preview in platform_previews:
        funnel = str(_as_dict(preview).get("funnel_stage") or "cold").lower()
        (cold_previews if funnel in {"cold", "tofu"} else warm_previews).append(_as_dict(preview))

    events: list[dict] = []
    cold_window = CAMPAIGN_COLD_WINDOW_DAYS
    warm_window = CAMPAIGN_WINDOW_DAYS - CAMPAIGN_COLD_WINDOW_DAYS

    for preview, offset in zip(cold_previews, _funnel_weighted_offsets(len(cold_previews), cold_window)):
        starts_at_dt = _schedule_event_time(start_of_day, offset)
        family_id = _as_str(preview.get("family_id"), _as_str(preview.get("platform_slug"), "preview"))
        events.append(
            {
                "id": f"evt-{_as_str(preview.get('platform_slug'), 'platform')}-{family_id}",
                "starts_at": _iso_z(starts_at_dt),
                "ends_at": None,
                "platform": _as_str(preview.get("platform_slug"), "unknown"),
                "platform_name": _as_str(preview.get("platform_name"), _as_str(preview.get("platform_slug"), "Platform")),
                "title": _as_str(preview.get("family_name"), _as_str(preview.get("headline"), "Scheduled campaign post")),
                "status": "planned",
                "funnel_stage": "cold",
                "asset_preview_id": _as_str(preview.get("asset_preview_id")) or None,
            }
        )

    for preview, offset in zip(warm_previews, _funnel_weighted_offsets(len(warm_previews), warm_window)):
        starts_at_dt = _schedule_event_time(start_of_day, CAMPAIGN_COLD_WINDOW_DAYS + offset)
        family_id = _as_str(preview.get("family_id"), _as_str(preview.get("platform_slug"), "preview"))
        events.append(
            {
                "id": f"evt-{_as_str(preview.get('platform_slug'), 'platform')}-{family_id}",
                "starts_at": _iso_z(starts_at_dt),
                "ends_at": None,
                "platform": _as_str(preview.get("platform_slug"), "unknown"),
                "platform_name": _as_str(preview.get("platform_name"), _as_str(preview.get("platform_slug"), "Platform")),
                "title": _as_str(preview.get("family_name"), _as_str(preview.get("headline"), "Scheduled campaign post")),
                "status": "planned",
                "funnel_stage": "warm",
                "asset_preview_id": _as_str(preview.get("asset_preview_id")) or None,
            }
        )

    events.sort(key=lambda event: event.get("starts_at") or "")
    return {
        "window_start": _iso_z(start_of_day),
        "window_end": _iso_z(start_of_day + timedelta(days=CAMPAIGN_WINDOW_DAYS)),
        "window_days": CAMPAIGN_WINDOW_DAYS,
        "cadence": "funnel-weighted",
        "events": events,
    }


def _stage3_static_asset_previews(production_handoff: dict) -> list[dict]:
    artifacts = _as_dict(_as_dict(production_handoff.get("artifacts")).get("ad_designer"))
    production_brief = _as_dict(artifacts.get("production_brief"))
    script_assets = _as_dict(artifacts.get("script_assets"))
    ad_artifacts = _as_dict(artifacts.get("artifacts"))
    hook = _as_str(_as_dict(script_assets.get("meta_ad_script")).get("hook"), _as_str(_as_dict(production_brief).get("core_message")))
    cta = _as_str(_as_dict(production_brief).get("primary_cta"))
    brief_proof_points = [
        line
        for line in _as_list(_as_dict(production_brief).get("proof_points"))
        if isinstance(line, str) and line.strip()
    ][:3]
    script_body = [
        line
        for line in _as_list(_as_dict(script_assets.get("meta_ad_script")).get("body"))
        if isinstance(line, str) and line.strip()
    ]

    family_images = _as_list(ad_artifacts.get("family_images"))
    if family_images:
        # One preview per family — this is the per-concept surface the dashboard
        # iterates to build the calendar tiles and the review UI cards.
        previews: list[dict] = []
        for index, family in enumerate(family_images):
            family_entry = _as_dict(family)
            image_path = _as_str(family_entry.get("image_path"))
            fallback_path = _as_str(family_entry.get("fallback_svg_path"))
            actual_media_paths = _existing_file_paths([image_path, fallback_path])
            if not actual_media_paths:
                continue
            family_hook = _as_str(family_entry.get("hook"), hook)
            family_angle = _as_str(family_entry.get("angle"))
            family_name = _as_str(family_entry.get("family_name"), _as_str(family_entry.get("family_id"), f"Family {index + 1}"))
            funnel_stage = _as_str(family_entry.get("funnel_stage"), "cold")
            family_id = _as_str(family_entry.get("family_id"), f"family-{index + 1}")
            caption_text = "\n".join([line for line in (family_angle, *script_body) if line])
            previews.append(
                {
                    "platform_slug": "meta-ads",
                    "platform_name": "Meta Feed",
                    "channel_type": "static",
                    "asset_preview_id": f"platform-preview-meta-ads-{family_id}",
                    "family_id": family_id,
                    "family_name": family_name,
                    "funnel_stage": funnel_stage,
                    "summary": f"{family_name} — Meta Feed concept ready for launch review.",
                    "headline": family_hook,
                    "caption_text": caption_text,
                    "cta": cta,
                    "hook": family_hook,
                    "proof_points": brief_proof_points,
                    "media_paths": actual_media_paths,
                    "expected_output_paths": [],
                    "preview_status": _preview_state(actual_media_paths),
                    "asset_paths": {
                        "spec_path": _as_str(ad_artifacts.get("canonical_spec_path"), _as_str(ad_artifacts.get("spec_path"))),
                        "generation_log_path": _as_str(_as_dict(family_entry.get("nano_banana")).get("output_path")),
                    },
                    "preview_text": "\n".join(
                        [
                            f"Family: {family_name} ({funnel_stage})",
                            f"Headline: {family_hook or 'n/a'}",
                            f"CTA: {cta or 'n/a'}",
                            *(f"Preview asset: {path}" for path in actual_media_paths[:2]),
                        ]
                    ),
                    "format": {
                        "aspect_ratio": _as_str(family_entry.get("aspect_ratio"), "4:5"),
                        "target_size": "1080x1350",
                    },
                }
            )
        if previews:
            return previews
        # Fall through to legacy behaviour when no family image actually rendered on disk.

    entries = [
        {
            "platform_slug": "meta-feed",
            "platform_name": "Meta Feed",
            "summary": "Stage-3 generated Meta Feed asset is ready for launch review.",
            "media_paths": _existing_file_paths(
                [
                    _as_str(ad_artifacts.get("meta_feed_image_path")),
                    _as_str(_as_dict(ad_artifacts.get("meta_feed_image_generation")).get("output_path")),
                ]
            ),
            "asset_paths": {
                "spec_path": _as_str(ad_artifacts.get("canonical_spec_path"), _as_str(ad_artifacts.get("spec_path"))),
                "generation_log_path": _as_str(_as_dict(ad_artifacts.get("meta_feed_image_generation")).get("output_path")),
            },
        },
        {
            "platform_slug": "meta-story",
            "platform_name": "Meta Story",
            "summary": "Stage-3 generated Meta Story asset is ready for launch review.",
            "media_paths": _existing_file_paths(
                [
                    _as_str(ad_artifacts.get("meta_story_image_path")),
                    _as_str(_as_dict(ad_artifacts.get("meta_story_image_generation")).get("output_path")),
                ]
            ),
            "asset_paths": {
                "spec_path": _as_str(ad_artifacts.get("canonical_spec_path"), _as_str(ad_artifacts.get("spec_path"))),
                "generation_log_path": _as_str(_as_dict(ad_artifacts.get("meta_story_image_generation")).get("output_path")),
            },
        },
    ]
    previews = []
    for entry in entries:
        actual_media_paths = entry["media_paths"]
        if not actual_media_paths:
            continue
        previews.append(
            {
                "platform_slug": entry["platform_slug"],
                "platform_name": entry["platform_name"],
                "channel_type": "static",
                "asset_preview_id": f"platform-preview-{entry['platform_slug']}",
                "summary": entry["summary"],
                "headline": hook,
                "caption_text": "\n".join(script_body),
                "cta": cta,
                "hook": hook,
                "proof_points": brief_proof_points,
                "media_paths": actual_media_paths,
                "expected_output_paths": [],
                "preview_status": _preview_state(actual_media_paths),
                "asset_paths": entry["asset_paths"],
                "preview_text": "\n".join(
                    [
                        f"Headline: {hook or 'n/a'}",
                        f"CTA: {cta or 'n/a'}",
                        *(f"Preview asset: {path}" for path in actual_media_paths[:2]),
                    ]
                ),
                "format": {
                    "aspect_ratio": "4:5" if entry["platform_slug"] == "meta-feed" else "9:16",
                    "target_size": "1080x1350" if entry["platform_slug"] == "meta-feed" else "1080x1920",
                },
            }
        )
    return previews


def _build_static_platform_previews(production_handoff: dict) -> list[dict]:
    static_handoff = _as_dict(_as_dict(production_handoff.get("contract_handoffs")).get("static"))
    previews = []
    for platform_entry in _as_list(static_handoff.get("platforms")):
        entry = _as_dict(platform_entry)
        contract = _read_json_file(_as_str(entry.get("contract_path")))
        creative = _as_dict(contract.get("creative"))
        landing_page = _as_dict(contract.get("landing_page"))
        expected_outputs = _as_dict(contract.get("expected_render_outputs"))
        body_lines = [line for line in _as_list(creative.get("body_lines")) if isinstance(line, str) and line.strip()]
        proof_points = [line for line in _as_list(creative.get("proof_points")) if isinstance(line, str) and line.strip()]
        actual_media_paths = _existing_preview_media_paths(
            [
                _as_str(expected_outputs.get("image_file")),
            ],
            STATIC_PREVIEW_SUFFIXES,
        )
        expected_output_paths = [
            path
            for path in [
                _as_str(expected_outputs.get("image_file")),
                _as_str(expected_outputs.get("copy_file")),
            ]
            if path
        ]
        preview_status = _preview_state(actual_media_paths)
        summary = (
            f"{_as_str(contract.get('platform'), _as_str(entry.get('platform'), 'Platform'))} static preview is backed by generated files."
            if actual_media_paths
            else f"{_as_str(contract.get('platform'), _as_str(entry.get('platform'), 'Platform'))} static contract is ready for review; render outputs are still expected only."
        )
        previews.append(
            {
                "platform_slug": _as_str(contract.get("platform_slug"), _as_str(entry.get("platform_slug"), "static-platform")),
                "platform_name": _as_str(contract.get("platform"), _as_str(entry.get("platform"), "Static platform")),
                "channel_type": "static",
                "summary": summary,
                "headline": _as_str(creative.get("headline")),
                "caption_text": "\n".join(body_lines),
                "cta": _as_str(creative.get("primary_cta")),
                "hook": _as_str(creative.get("headline")),
                "proof_points": proof_points,
                "media_paths": actual_media_paths,
                "expected_output_paths": expected_output_paths,
                "preview_status": preview_status,
                "asset_paths": {
                    "contract_path": _as_str(entry.get("contract_path")),
                    "brief_path": _as_str(entry.get("brief_path")),
                    "landing_page_path": _as_str(landing_page.get("slug")),
                },
                "preview_text": "\n".join(
                    [
                        "Status: generated preview." if actual_media_paths else "Status: contract-only; no rendered preview file exists.",
                        f"Headline: {_as_str(creative.get('headline'), 'n/a')}",
                        *(f"- {line}" for line in body_lines[:3]),
                        f"CTA: {_as_str(creative.get('primary_cta'), 'n/a')}",
                        *(f"Proof: {point}" for point in proof_points[:3]),
                        *(f"Preview asset: {path}" for path in actual_media_paths[:2]),
                    ]
                ),
                "format": {
                    "aspect_ratio": _as_str(_as_dict(contract.get("layout")).get("aspect_ratio")),
                    "target_size": _as_str(_as_dict(contract.get("layout")).get("target_size")),
                },
            }
        )
    return previews


def _build_video_platform_previews(production_handoff: dict) -> list[dict]:
    video_handoff = _as_dict(_as_dict(production_handoff.get("contract_handoffs")).get("video"))
    previews = []
    for platform_entry in _as_list(video_handoff.get("platforms")):
        entry = _as_dict(platform_entry)
        contract = _read_json_file(_as_str(entry.get("contract_path")))
        creative = _as_dict(contract.get("creative"))
        requirements = _as_dict(contract.get("platform_requirements"))
        expected_outputs = _as_dict(contract.get("expected_render_outputs"))
        actual_media_paths = _existing_preview_media_paths(
            [
                _as_str(expected_outputs.get("poster_file")),
                _as_str(expected_outputs.get("video_file")),
            ],
            VIDEO_PREVIEW_SUFFIXES,
        )
        expected_output_paths = [
            path
            for path in [
                _as_str(expected_outputs.get("poster_file")),
                _as_str(expected_outputs.get("video_file")),
                _as_str(expected_outputs.get("captions_file")),
                _as_str(expected_outputs.get("project_file")),
            ]
            if path
        ]
        story_beats = [
            _as_str(_as_dict(beat).get("description"))
            for beat in _as_list(creative.get("story_beats"))
            if _as_str(_as_dict(beat).get("description"))
        ]
        voiceover_lines = [line for line in _as_list(creative.get("voiceover_lines")) if isinstance(line, str) and line.strip()]
        previews.append(
            {
                "platform_slug": _as_str(contract.get("platform_slug"), _as_str(entry.get("platform_slug"), "video-platform")),
                "platform_name": _as_str(contract.get("platform"), _as_str(entry.get("platform"), "Video platform")),
                "channel_type": "video",
                "summary": (
                    f"{_as_str(contract.get('platform'), _as_str(entry.get('platform'), 'Platform'))} video preview is backed by generated files."
                    if actual_media_paths
                    else f"{_as_str(contract.get('platform'), _as_str(entry.get('platform'), 'Platform'))} video contract is ready for review; no rendered poster or video exists yet."
                ),
                "headline": _as_str(creative.get("summary")),
                "caption_text": "\n".join(voiceover_lines),
                "cta": _as_str(creative.get("primary_cta")),
                "hook": _as_str(creative.get("opening_line")),
                "proof_points": story_beats,
                "media_paths": actual_media_paths,
                "expected_output_paths": expected_output_paths,
                "preview_status": _preview_state(actual_media_paths),
                "asset_paths": {
                    "contract_path": _as_str(entry.get("contract_path")),
                    "brief_path": _as_str(entry.get("brief_path")),
                },
                "preview_text": "\n".join(
                    [
                        "Status: generated preview." if actual_media_paths else "Status: contract-only; no rendered poster or video file exists.",
                        f"Opening line: {_as_str(creative.get('opening_line'), 'n/a')}",
                        *(f"- {line}" for line in voiceover_lines[:4]),
                        f"CTA: {_as_str(creative.get('primary_cta'), 'n/a')}",
                        *(f"Beat: {beat}" for beat in story_beats[:4]),
                        *(f"Preview asset: {path}" for path in actual_media_paths[:2]),
                    ]
                ),
                "format": {
                    "aspect_ratio": _as_str(requirements.get("aspect_ratio")),
                    "target_duration_seconds": _as_str(requirements.get("target_duration_seconds")),
                    "max_duration_seconds": _as_str(requirements.get("max_duration_seconds")),
                },
            }
        )
    return previews


def _build_review_bundle(data: dict, preview_path: str, approval_message: str, launch_approved: bool) -> dict:
    handoff = _as_dict(data.get("production_handoff"))
    production_brief = _as_dict(handoff.get("production_brief"))
    artifacts = _as_dict(handoff.get("artifacts"))
    page_designer = _as_dict(artifacts.get("page_designer"))
    scriptwriter = _as_dict(artifacts.get("scriptwriter"))
    production_review = _as_dict(artifacts.get("production_review_preview"))
    page_assets = _as_dict(page_designer.get("page_assets"))
    landing_page = _as_dict(page_assets.get("landing_page"))
    page_artifacts = _as_dict(page_designer.get("artifacts"))
    script_assets = _as_dict(scriptwriter.get("script_assets"))
    script_artifacts = _as_dict(scriptwriter.get("artifacts"))
    static_handoff = _as_dict(_as_dict(handoff.get("contract_handoffs")).get("static"))
    video_handoff = _as_dict(_as_dict(handoff.get("contract_handoffs")).get("video"))
    platform_previews = [
        *_stage3_static_asset_previews(handoff),
        *_build_static_platform_previews(handoff),
        *_build_video_platform_previews(handoff),
    ]
    approved_at = datetime.now(timezone.utc)
    content_calendar = _build_content_calendar(platform_previews, approved_at)
    generated_post_count = len([p for p in platform_previews if _as_list(_as_dict(p).get("media_paths"))])
    return {
        "schema_version": "2026-03-20.launch-review-bundle.v1",
        "campaign_name": _as_str(handoff.get("campaign_name"), _as_str(data.get("campaign_name"))),
        "approval_status": "approved" if launch_approved else "pending_human_review",
        "approval_message": approval_message,
        "summary": {
            "core_message": _as_str(production_brief.get("core_message")),
            "primary_cta": _as_str(production_brief.get("primary_cta")),
            "offer_summary": _as_str(production_brief.get("offer_summary")),
            "static_contract_count": len(_as_list(static_handoff.get("platform_contract_paths"))),
            "video_contract_count": len(_as_list(video_handoff.get("platform_contract_paths"))),
            "launch_readiness_status": _as_str(_as_dict(handoff.get("launch_readiness")).get("status")),
            "planned_posts": len(content_calendar.get("events", [])),
            "created_posts": generated_post_count,
            "campaign_window": {
                "start": content_calendar.get("window_start"),
                "end": content_calendar.get("window_end"),
                "duration_days": content_calendar.get("window_days"),
            },
        },
        "content_calendar": content_calendar,
        "landing_page_preview": {
            "slug": _as_str(landing_page.get("slug")),
            "headline": _as_str(landing_page.get("hero_headline")),
            "subheadline": _as_str(landing_page.get("hero_subheadline")),
            "cta": _as_str(landing_page.get("primary_cta")),
            "sections": [item for item in _as_list(landing_page.get("sections")) if isinstance(item, str) and item.strip()],
            "message_match_checks": [
                item for item in _as_list(landing_page.get("message_match_checks")) if isinstance(item, str) and item.strip()
            ],
            "landing_page_path": _as_str(page_artifacts.get("landing_page_path")),
            "preview_path": _as_str(page_artifacts.get("preview_path")),
        },
        "script_preview": {
            "meta_ad_hook": _as_str(_as_dict(script_assets.get("meta_ad_script")).get("hook")),
            "meta_ad_body": [
                item for item in _as_list(_as_dict(script_assets.get("meta_ad_script")).get("body"))
                if isinstance(item, str) and item.strip()
            ],
            "short_video_opening_line": _as_str(_as_dict(script_assets.get("short_video_script")).get("opening_line")),
            "short_video_beats": [
                item for item in _as_list(_as_dict(script_assets.get("short_video_script")).get("beats"))
                if isinstance(item, str) and item.strip()
            ],
            "meta_script_path": _as_str(script_artifacts.get("meta_script_path")),
            "short_video_script_path": _as_str(script_artifacts.get("short_video_script_path")),
            "preview_path": _as_str(script_artifacts.get("preview_path")),
        },
        "review_packet": {
            "production_review_preview_path": _as_str(_as_dict(production_review.get("artifacts")).get("preview_path")),
            "canonical_review_packet_path": _as_str(_as_dict(production_review.get("artifacts")).get("canonical_preview_path")),
            "review_summary": _as_str(_as_dict(_as_dict(production_review.get("review_packet")).get("summary")).get("core_message")),
        },
        "platform_previews": platform_previews,
        "artifact_paths": {
            "preview_path": preview_path,
            "static_output_root": _as_str(static_handoff.get("output_root")),
            "static_platform_index_path": _as_str(static_handoff.get("platform_index_path")),
            "video_output_root": _as_str(video_handoff.get("output_root")),
            "video_platform_index_path": _as_str(video_handoff.get("platform_index_path")),
        },
    }


def _validate_review_bundle(review_bundle: dict) -> None:
    landing_page_preview = _as_dict(review_bundle.get("landing_page_preview"))
    script_preview = _as_dict(review_bundle.get("script_preview"))
    summary = _as_dict(review_bundle.get("summary"))
    validate_copy_text("launch_review.summary.core_message", _as_str(summary.get("core_message")), min_tokens=3)
    validate_copy_text("launch_review.summary.primary_cta", _as_str(summary.get("primary_cta")), min_tokens=2)
    validate_copy_text("launch_review.landing_page.headline", _as_str(landing_page_preview.get("headline")), min_tokens=3)
    validate_copy_text("launch_review.landing_page.subheadline", _as_str(landing_page_preview.get("subheadline")), min_tokens=4)
    validate_copy_text("launch_review.landing_page.cta", _as_str(landing_page_preview.get("cta")), min_tokens=2)
    validate_copy_text("launch_review.script.meta_hook", _as_str(script_preview.get("meta_ad_hook")), min_tokens=3)
    validate_copy_text("launch_review.script.video_opening_line", _as_str(script_preview.get("short_video_opening_line")), min_tokens=3)
    validate_unique_copy_list("launch_review.script.meta_body", script_preview.get("meta_ad_body"), min_items=1, max_items=4, min_tokens=3)
    validate_unique_copy_list("launch_review.script.video_beats", script_preview.get("short_video_beats"), min_items=3, max_items=4, min_tokens=3)
    for platform in _as_list(review_bundle.get("platform_previews")):
        platform_dict = _as_dict(platform)
        validate_copy_text(
            f"launch_review.platform.{_as_str(platform_dict.get('platform_slug'), 'platform')}.summary",
            _as_str(platform_dict.get("summary")),
            min_tokens=3,
        )
        validate_copy_text(
            f"launch_review.platform.{_as_str(platform_dict.get('platform_slug'), 'platform')}.headline",
            _as_str(platform_dict.get("headline")),
            min_tokens=3,
        )
        validate_copy_text(
            f"launch_review.platform.{_as_str(platform_dict.get('platform_slug'), 'platform')}.cta",
            _as_str(platform_dict.get("cta")),
            min_tokens=2,
        )


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--launch-approved", default="false")
    parser.add_argument("--notify-chat", default="true")
    args = parser.parse_args()

    data = read_stdin_json()
    brand_slug = slugify(args.brand_slug or data.get("brand_slug", "client-brand"))
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, data.get("campaign_name", ""))
    plan = data.get("publish_plan", {})
    launch_approved = _as_bool(args.launch_approved)
    approval_message = (
        f"Approval needed: marketing pipeline launch review for {data.get('campaign_name', brand_slug)}. "
        f"Static assets: {plan.get('static_contract_count', 0)}. Video assets: {plan.get('video_contract_count', 0)}. "
        "Reply with approval and rerun with launch_approved=true to generate publish-ready assets."
    )
    review_bundle = _build_review_bundle(data, "", approval_message, launch_approved)
    _validate_review_bundle(review_bundle)
    preview_lines = [
        f"Campaign: {review_bundle.get('campaign_name', '')}",
        f"Core message: {_as_str(_as_dict(review_bundle.get('summary')).get('core_message'), 'n/a')}",
        f"Primary CTA: {_as_str(_as_dict(review_bundle.get('summary')).get('primary_cta'), 'n/a')}",
        f"Static contracts: {plan.get('static_contract_count', 0)}",
        f"Video contracts: {plan.get('video_contract_count', 0)}",
        f"Approval state: {'approved' if launch_approved else 'pending_human_review'}",
        "",
        "Landing page preview:",
        f"- Headline: {_as_str(_as_dict(review_bundle.get('landing_page_preview')).get('headline'), 'n/a')}",
        f"- Subheadline: {_as_str(_as_dict(review_bundle.get('landing_page_preview')).get('subheadline'), 'n/a')}",
        f"- CTA: {_as_str(_as_dict(review_bundle.get('landing_page_preview')).get('cta'), 'n/a')}",
        "",
        "Script preview:",
        f"- Meta hook: {_as_str(_as_dict(review_bundle.get('script_preview')).get('meta_ad_hook'), 'n/a')}",
        f"- Video opening line: {_as_str(_as_dict(review_bundle.get('script_preview')).get('short_video_opening_line'), 'n/a')}",
        "",
        "Platform previews:",
    ]
    for platform in _as_list(review_bundle.get("platform_previews")):
        platform_dict = _as_dict(platform)
        preview_text = _as_str(platform_dict.get("preview_text"))
        preview_lines.extend(
            [
                (
                    f"- {_as_str(platform_dict.get('platform_name'), _as_str(platform_dict.get('platform_slug'), 'Platform'))} "
                    f"[{_as_str(platform_dict.get('channel_type'), 'draft')} | {_as_str(platform_dict.get('preview_status'), 'contract_only')}]"
                ),
                f"  Hook: {_as_str(platform_dict.get('hook'), 'n/a')}",
                f"  CTA: {_as_str(platform_dict.get('cta'), 'n/a')}",
                *(f"  {line}" for line in preview_text.splitlines()[:4] if line.strip()),
            ]
        )
    preview_lines.append("")
    preview_lines.append("Launch review remains a human approval gate.")
    preview = "\n".join(preview_lines)
    preview_path = save_artifact_text(run_id, "launch-review-preview/preview.txt", preview)
    review_bundle["artifact_paths"]["preview_path"] = preview_path
    notification = {
        "executed": False,
        "status": "skipped",
        "stdout": "",
        "stderr": "",
        "returncode": None,
    }
    if (not launch_approved) and _as_bool(args.notify_chat):
        notification = openclaw_system_event(approval_message, mode="now")
    payload = {
        "type": "launch_review_preview",
        "mode": "compiled",
        "generated_at": utc_now(),
        "run_id": run_id,
        "brand_slug": brand_slug,
        "approval_preview": {
            "status": "approved" if launch_approved else "pending_human_review",
            "reason": "Stage 4 launch review remains a human approval step in the Lobster workflow.",
            "message": approval_message,
        },
        "review_bundle": review_bundle,
        "artifacts": {
            "preview_path": preview_path,
        },
        "chat_notification": notification,
    }
    save_step(run_id, "launch_review_preview", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
