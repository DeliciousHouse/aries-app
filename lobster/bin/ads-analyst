#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _stage1_common import emit_json, load_step, read_stdin_json, save_step, utc_now
from _canonical_outputs import competitor_output_paths, write_json, write_text


def compile_report(creative_data: dict) -> dict:
    run_id = creative_data.get("run_id")
    ad_analysis = load_step(run_id, "meta_ads_analyser") if run_id else None
    extractor_data = load_step(run_id, "meta_ads_extractor") if run_id else None

    creative_findings = creative_data.get("creative_findings", [])
    top_creative = creative_findings[0]["winning_pattern"] if creative_findings else "proof-led messaging"
    top_hook = ((ad_analysis or {}).get("summary", {}).get("top_hooks") or ["outcome-focused proof"])[0]
    extractor = extractor_data or {}
    competitor_identity = extractor.get("competitorIdentity", {}) if isinstance(extractor.get("competitorIdentity"), dict) else {}
    meta_locator = extractor.get("metaLocator", {}) if isinstance(extractor.get("metaLocator"), dict) else {}
    evidence = extractor.get("evidence", {}) if isinstance(extractor.get("evidence"), dict) else {}
    trust_validation = extractor.get("trustValidation", {}) if isinstance(extractor.get("trustValidation"), dict) else {}
    stage1_summary = {
        "competitor": creative_data.get("competitor") or extractor.get("competitor", ""),
        "competitor_url": extractor.get("competitor_url"),
        "competitor_facebook_url": extractor.get("competitor_facebook_url", ""),
        "competitorIdentity": competitor_identity,
        "metaLocator": meta_locator,
        "evidence": evidence,
        "trustValidation": trust_validation,
    }

    payload = {
        "type": "ads_analyst_compile",
        "stub": False,
        "mode": creative_data.get("mode", "derived"),
        "generated_at": utc_now(),
        "run_id": run_id,
        "competitor": stage1_summary["competitor"],
        "competitor_url": stage1_summary["competitor_url"],
        "competitor_facebook_url": stage1_summary["competitor_facebook_url"],
        "competitorIdentity": competitor_identity,
        "metaLocator": meta_locator,
        "evidence": evidence,
        "trustValidation": trust_validation,
        "inputs": {
            "ads_seen": len(extractor.get("ads", [])),
            "creative_findings": len(creative_findings),
            "campaign_angles_detected": len((ad_analysis or {}).get("summary", {}).get("top_hooks", [])),
        },
        "executive_summary": {
            "market_positioning": f"Competitor is leaning on {top_creative} to create mid-funnel confidence.",
            "creative_takeaway": f"Best observed creative pattern: {top_creative}.",
            "campaign_takeaway": f"Dominant campaign angle observed: {top_hook}.",
        },
        "recommended_actions": [
            "Test one proof-first creative against one differentiation-led creative.",
            "Mirror the competitor's strongest hook with a differentiated proof claim.",
            "Keep CTA language aligned with the winning campaign angle per ad variant.",
        ],
        "stage1_summary": stage1_summary,
        "artifacts": {
            "meta_ads_extract": extractor_data,
            "meta_ads_analysis": ad_analysis,
            "ad_creative_analysis": creative_data,
        },
    }
    if run_id:
        competitor = payload["competitor"] or "competitor"
        paths = competitor_output_paths(competitor)
        summary_markdown = "\n".join(
            [
                f"# {competitor} Competitor Research Summary",
                "",
                "## Executive Summary",
                f"- Market positioning: {payload['executive_summary']['market_positioning']}",
                f"- Creative takeaway: {payload['executive_summary']['creative_takeaway']}",
                f"- Campaign takeaway: {payload['executive_summary']['campaign_takeaway']}",
                "",
                "## Recommended Actions",
                *[f"- {item}" for item in payload["recommended_actions"]],
            ]
        )
        summary_html = "".join(
            [
                "<html><body>",
                f"<h1>{competitor} Competitor Research Summary</h1>",
                "<h2>Executive Summary</h2>",
                "<ul>",
                f"<li><strong>Market positioning:</strong> {payload['executive_summary']['market_positioning']}</li>",
                f"<li><strong>Creative takeaway:</strong> {payload['executive_summary']['creative_takeaway']}</li>",
                f"<li><strong>Campaign takeaway:</strong> {payload['executive_summary']['campaign_takeaway']}</li>",
                "</ul>",
                "<h2>Recommended Actions</h2><ul>",
                *[f"<li>{item}</li>" for item in payload["recommended_actions"]],
                "</ul></body></html>",
            ]
        )
        payload["artifacts"] = {
            **payload.get("artifacts", {}),
            "summary_json_path": write_json(paths["summary_json"], payload),
            "summary_markdown_path": write_text(paths["summary_md"], summary_markdown),
            "summary_html_path": write_text(paths["summary_html"], summary_html),
        }
        save_step(run_id, "ads_analyst_compile", payload)
    return payload


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--mode", default="compile")
    args = parser.parse_args()

    data = read_stdin_json()
    if args.mode != "compile":
        emit_json(
            {
                "type": "ads_analyst",
                "stub": True,
                "generated_at": utc_now(),
                "mode": args.mode,
                "message": "Only compile mode is implemented in the local stage-1 wrapper.",
            }
        )
        return 0

    emit_json(compile_report(data))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
