#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _marketing_profile_common import (
    record_or_empty,
    validate_copy_text,
    validate_unique_copy_list,
)
from _stage3_common import emit_json, ensure_run_id, normalize_research_model, read_stdin_json, save_artifact_text, save_step, slugify, utc_now
from _canonical_outputs import brand_output_paths, write_text


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    data = read_stdin_json()
    brief = record_or_empty(data.get("production_brief"))
    creative_handoff = record_or_empty(brief.get("creative_handoff"))
    hooks = record_or_empty(creative_handoff.get("hooks"))
    opening_lines = record_or_empty(creative_handoff.get("opening_lines"))
    meta_hooks = hooks.get("meta") if isinstance(hooks.get("meta"), list) else []
    video_opening_lines = opening_lines.get("video") if isinstance(opening_lines.get("video"), list) else []
    brand_slug = slugify(args.brand_slug or data.get("brand_slug", "client-brand"))
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, brief.get("campaign_name", ""))
    meta_hook = validate_copy_text("script.meta_hook", meta_hooks[0] if meta_hooks else brief.get("core_message"), min_tokens=3)
    offer_summary = validate_copy_text("script.offer_summary", brief.get("offer_summary"), min_tokens=4)
    problem_statement = validate_copy_text("script.problem_statement", brief.get("problem_statement"), min_tokens=4)
    primary_cta = validate_copy_text("script.primary_cta", brief.get("primary_cta"), min_tokens=2)
    proof_points = validate_unique_copy_list("script.proof_points", brief.get("proof_points"), min_items=3, max_items=3, min_tokens=3)
    video_opening_line = validate_copy_text(
        "script.video_opening_line",
        video_opening_lines[0] if video_opening_lines else meta_hook,
        min_tokens=3,
    )

    # Per-family script variants. Upstream campaign-planner emits
    # testing_matrix.{meta,video}.{cold_funnel,warm_funnel} with 2 families
    # each (4 total per channel) — every family carries its own primary_hook,
    # opening_line, angle, proof_variants, offer_variants. Scriptwriter
    # previously only read [0] from the shared hooks list and collapsed all
    # 4 families to one hook; downstream preview + ad-designer consumers
    # then repeated that single hook across 18 platforms. Emit per-family
    # script bundles here so consumers can read per-family copy directly.
    # Legacy meta_ad_script / short_video_script fields stay populated from
    # the first family (or brief fallback) for back-compat.
    testing_matrix = record_or_empty(brief.get("testing_matrix"))

    def _iter_families(channel_key: str) -> list[dict]:
        channel_matrix = record_or_empty(testing_matrix.get(channel_key))
        families: list[dict] = []
        for funnel_key in ("cold_funnel", "warm_funnel"):
            raw = channel_matrix.get(funnel_key)
            if isinstance(raw, list):
                for entry in raw:
                    if isinstance(entry, dict):
                        families.append(entry)
        return families

    def _family_str(value) -> str:
        if isinstance(value, str):
            stripped = value.strip()
            if stripped:
                return stripped
        return ""

    def _family_list(value) -> list[str]:
        if not isinstance(value, list):
            return []
        return [item.strip() for item in value if isinstance(item, str) and item.strip()]

    meta_ad_scripts_by_family: dict[str, dict] = {}
    for family in _iter_families("meta"):
        family_id = _family_str(family.get("family_id"))
        family_hook = _family_str(family.get("primary_hook"))
        family_opening = _family_str(family.get("opening_line"))
        if not family_id or not family_hook or not family_opening:
            continue
        family_angle = _family_str(family.get("angle")) or problem_statement
        offer_variants = _family_list(family.get("offer_variants"))
        family_offer = offer_variants[0] if offer_variants else offer_summary
        family_proofs = _family_list(family.get("proof_variants")) or proof_points[:2]
        meta_ad_scripts_by_family[family_id] = {
            "family_id": family_id,
            "family_name": _family_str(family.get("family_name")) or family_id,
            "funnel_stage": _family_str(family.get("funnel_stage")) or "cold",
            "hook": family_hook,
            "body": [family_opening, family_angle, family_offer],
            "proof_points": family_proofs,
            "primary_cta": primary_cta,
        }

    short_video_scripts_by_family: dict[str, dict] = {}
    for family in _iter_families("video"):
        family_id = _family_str(family.get("family_id"))
        family_hook = _family_str(family.get("primary_hook"))
        family_opening = _family_str(family.get("opening_line"))
        if not family_id or not family_hook or not family_opening:
            continue
        family_angle = _family_str(family.get("angle")) or problem_statement
        offer_variants = _family_list(family.get("offer_variants"))
        family_offer = offer_variants[0] if offer_variants else offer_summary
        family_proofs = _family_list(family.get("proof_variants"))
        proof_line = family_proofs[0] if family_proofs else proof_points[0]
        short_video_scripts_by_family[family_id] = {
            "family_id": family_id,
            "family_name": _family_str(family.get("family_name")) or family_id,
            "funnel_stage": _family_str(family.get("funnel_stage")) or "cold",
            "opening_line": family_opening,
            "voiceover_lines": [family_hook, family_opening, family_angle],
            "beats": [family_angle, proof_line, family_offer, f"{primary_cta}."],
            "duration_seconds": 30,
        }

    script_assets = {
        "meta_ad_script": {
            "hook": meta_hook,
            "body": [
                problem_statement,
                f"{offer_summary} {proof_points[0]}",
                f"{primary_cta}.",
            ],
            "duration_seconds": 30,
        },
        "short_video_script": {
            "opening_line": video_opening_line,
            "beats": [
                problem_statement,
                offer_summary,
                proof_points[0],
                primary_cta,
            ],
            "duration_seconds": 30,
        },
        "voiceover_options": [
            f"{meta_hook} {problem_statement}",
            f"{video_opening_line} {offer_summary}",
        ],
        "proof_points": proof_points,
        "meta_ad_scripts_by_family": meta_ad_scripts_by_family,
        "short_video_scripts_by_family": short_video_scripts_by_family,
    }

    preview_text = "\n".join(
        [
            f"Hook: {script_assets['meta_ad_script']['hook']}",
            "Meta body:",
            *[f"- {line}" for line in script_assets["meta_ad_script"]["body"]],
            "Video beats:",
            *[f"- {line}" for line in script_assets["short_video_script"]["beats"]],
        ]
    )
    preview_path = save_artifact_text(run_id, "scriptwriter/scripts-preview.txt", preview_text)
    paths = brand_output_paths(brand_slug)
    scripts_dir = paths["scripts_dir"]
    meta_script_path = write_text(
        scripts_dir / "meta-ad-script.md",
        "\n".join(
            [
                f"# Meta Ad Script — {brand_slug}",
                "",
                f"## Hook\n{script_assets['meta_ad_script']['hook']}",
                "",
                "## Body",
                *[f"- {line}" for line in script_assets["meta_ad_script"]["body"]],
                "",
                f"## CTA\n{primary_cta}",
            ]
        ),
    )
    short_video_path = write_text(
        scripts_dir / "short-video-script.md",
        "\n".join(
            [
                f"# Short Video Script — {brand_slug}",
                "",
                f"## Opening Line\n{script_assets['short_video_script']['opening_line']}",
                "",
                "## Beats",
                *[f"- {line}" for line in script_assets["short_video_script"]["beats"]],
                "",
                f"## CTA\n{primary_cta}",
            ]
        ),
    )

    payload = {
        "type": "scriptwriter",
        "stub": False,
        "mode": "live",
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": brand_slug,
        "production_brief": brief,
        "script_assets": script_assets,
        "artifacts": {
            "preview_path": preview_path,
            "meta_script_path": meta_script_path,
            "short_video_script_path": short_video_path,
            "honesty_note": "This local wrapper drafts scripts and beat sheets only; no human talent, voice synthesis, or production system is invoked.",
        },
    }
    save_step(run_id, "scriptwriter", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
