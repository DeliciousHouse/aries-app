#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _marketing_profile_common import record_or_empty
from _stage2_common import emit_json, normalize_research_model, read_stdin_json, save_step, utc_now
from _stage2_common import ensure_run_id
from _canonical_outputs import brand_output_paths, write_text


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--mode", default="finalize")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    data = read_stdin_json()
    plan = record_or_empty(data.get("campaign_plan"))
    record = record_or_empty(data.get("brand_profiles_record"))
    creative_handoff = record_or_empty(data.get("creative_handoff") or record.get("creative_handoff"))
    brand_slug = record.get("brand_slug", args.brand_slug)
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, plan.get("campaign_name", ""))
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))

    strategy_handoff = {
        "campaign_name": plan.get("campaign_name", ""),
        "objective": plan.get("objective", ""),
        "core_message": plan.get("core_message", ""),
        "primary_cta": plan.get("primary_cta", ""),
        "offer_summary": plan.get("offer", ""),
        "audience_summary": plan.get("audience", ""),
        "positioning": plan.get("positioning", ""),
        "problem_statement": plan.get("problem_statement", ""),
        "proof_points": plan.get("proof_points", []),
        "channels": plan.get("channel_plans", []),
        "brand_profile_id": record.get("tenant_id", brand_slug),
        "brand_profile_path": record.get("validated_brand_profile_path", ""),
        "creative_handoff": creative_handoff,
    }

    payload = {
        "type": "head_of_marketing",
        "stub": False,
        "mode": args.mode,
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": brand_slug,
        "strategy_handoff": strategy_handoff,
    }
    paths = brand_output_paths(record.get("brand_slug", args.brand_slug))
    proposal_md = "\n".join(
        [
            f"# {record.get('brand_name', payload['brand_slug'])} Campaign Proposal",
            "",
            f"- Campaign: {plan.get('campaign_name', '')}",
            f"- Objective: {plan.get('objective', '')}",
            f"- Primary CTA: {plan.get('primary_cta', '')}",
            "",
            "## Audience",
            plan.get("audience", ""),
            "",
            "## Positioning",
            plan.get("positioning", ""),
            "",
            "## Problem Statement",
            plan.get("problem_statement", ""),
            "",
            "## Offer",
            plan.get("offer", ""),
            "",
            "## Proof Points",
            *[f"- {item}" for item in plan.get("proof_points", [])],
            "",
            "## Channel Plans",
            *[
                f"- {channel.get('channel', 'channel')}: {channel.get('message', '')} | Hook: {channel.get('hook', '')} | CTA: {channel.get('cta', '')}"
                for channel in plan.get("channel_plans", [])
            ],
        ]
    )
    proposal_html = "".join(
        [
            "<html><body>",
            f"<h1>{record.get('brand_name', payload['brand_slug'])} Campaign Proposal</h1>",
            f"<p><strong>Campaign:</strong> {plan.get('campaign_name', '')}</p>",
            f"<p><strong>Objective:</strong> {plan.get('objective', '')}</p>",
            f"<p><strong>Primary CTA:</strong> {plan.get('primary_cta', '')}</p>",
            f"<h2>Audience</h2><p>{plan.get('audience', '')}</p>",
            f"<h2>Positioning</h2><p>{plan.get('positioning', '')}</p>",
            f"<h2>Problem Statement</h2><p>{plan.get('problem_statement', '')}</p>",
            f"<h2>Offer</h2><p>{plan.get('offer', '')}</p>",
            "<h2>Proof Points</h2><ul>",
            *[f"<li>{item}</li>" for item in plan.get("proof_points", [])],
            "</ul><h2>Channel Plans</h2><ul>",
            *[
                f"<li><strong>{channel.get('channel', 'channel')}</strong>: {channel.get('message', '')} (Hook: {channel.get('hook', '')}; CTA: {channel.get('cta', '')})</li>"
                for channel in plan.get("channel_plans", [])
            ],
            "</ul></body></html>",
        ]
    )
    payload["artifacts"] = {
        "campaign_proposal_markdown_path": write_text(paths["campaign_proposal_md"], proposal_md),
        "campaign_proposal_html_path": write_text(paths["campaign_proposal_html"], proposal_html),
    }
    save_step(run_id, "head_of_marketing", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
