#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _marketing_profile_common import record_or_empty
from _brand_identity_common import build_brand_identity
from _stage2_common import emit_json, normalize_research_model, read_stdin_json, save_step, utc_now
from _stage2_common import ensure_run_id
from _canonical_outputs import brand_output_paths, write_text


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--mode", default="finalize")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    data = read_stdin_json()
    plan = record_or_empty(data.get("campaign_plan"))
    record = record_or_empty(data.get("brand_profiles_record"))
    creative_handoff = record_or_empty(data.get("creative_handoff") or record.get("creative_handoff"))
    brand_slug = record.get("brand_slug", args.brand_slug)
    run_id = ensure_run_id(data.get("run_id", ""), brand_slug, plan.get("campaign_name", ""))
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))

    strategy_handoff = {
        "campaign_name": plan.get("campaign_name", ""),
        "objective": plan.get("objective", ""),
        "core_message": plan.get("core_message", ""),
        "primary_cta": plan.get("primary_cta", ""),
        "offer_summary": plan.get("offer", ""),
        "audience_summary": plan.get("audience", ""),
        "positioning": plan.get("positioning", ""),
        "problem_statement": plan.get("problem_statement", ""),
        "proof_points": plan.get("proof_points", []),
        "channels": plan.get("channel_plans", []),
        "competitor_context": plan.get("competitor_context", {}),
        "testing_matrix": plan.get("testing_matrix", {}),
        "budget_testing_plan": plan.get("budget_testing_plan", {}),
        "brand_profile_id": record.get("tenant_id", brand_slug),
        "brand_profile_path": record.get("validated_brand_profile_path", ""),
        "creative_handoff": creative_handoff,
        "design_tokens": creative_handoff.get("design_tokens", {}),
        "brand_kit": creative_handoff.get("brand_kit", {}),
    }
    strategy_handoff["brandIdentity"] = build_brand_identity(
        {
            "website_url": creative_handoff.get("website_url") or record.get("website_url"),
            "canonical_url": record.get("canonical_url"),
            "audience": creative_handoff.get("audience") or strategy_handoff.get("audience_summary"),
            "positioning": creative_handoff.get("positioning") or strategy_handoff.get("positioning"),
            "offer": creative_handoff.get("offer") or strategy_handoff.get("offer_summary"),
            "brand_promise": creative_handoff.get("brand_promise"),
            "primary_cta": creative_handoff.get("primary_cta") or strategy_handoff.get("primary_cta"),
            "proof_points": creative_handoff.get("proof_points") or strategy_handoff.get("proof_points"),
            "brand_voice": creative_handoff.get("brand_voice"),
            "style_vibe": creative_handoff.get("style_vibe"),
            "brand_kit": creative_handoff.get("brand_kit", {}),
            "hooks": creative_handoff.get("hooks", {}),
        }
    )

    payload = {
        "type": "head_of_marketing",
        "stub": False,
        "mode": args.mode,
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": brand_slug,
        "strategy_handoff": strategy_handoff,
    }
    paths = brand_output_paths(record.get("brand_slug", args.brand_slug))
    proposal_md = "\n".join(
        [
            f"# {record.get('brand_name', payload['brand_slug'])} Campaign Proposal",
            "",
            f"- Campaign: {plan.get('campaign_name', '')}",
            f"- Objective: {plan.get('objective', '')}",
            f"- Primary CTA: {plan.get('primary_cta', '')}",
            "",
            "## Audience",
            plan.get("audience", ""),
            "",
            "## Positioning",
            plan.get("positioning", ""),
            "",
            "## Problem Statement",
            plan.get("problem_statement", ""),
            "",
            "## Offer",
            plan.get("offer", ""),
            "",
            "## Proof Points",
            *[f"- {item}" for item in plan.get("proof_points", [])],
            "",
            "## Channel Plans",
            *[
                f"- {channel.get('channel', 'channel')}: {channel.get('message', '')} | Hook: {channel.get('hook', '')} | CTA: {channel.get('cta', '')} | Hypothesis: {channel.get('hypothesis', '')}"
                for channel in plan.get("channel_plans", [])
            ],
            "",
            "## Competitor Context",
            f"- Competitor input: {plan.get('competitor_context', {}).get('competitor', '')}",
            f"- Market positioning: {plan.get('competitor_context', {}).get('market_positioning', '')}",
            f"- Creative takeaway: {plan.get('competitor_context', {}).get('creative_takeaway', '')}",
            f"- Campaign takeaway: {plan.get('competitor_context', {}).get('campaign_takeaway', '')}",
            *[f"- Recommended action: {item}" for item in plan.get("competitor_context", {}).get("recommended_actions", [])],
            "",
            "## Testing Matrix",
            *[
                line
                for channel_name, matrix in plan.get("testing_matrix", {}).items()
                for line in [
                    f"### {channel_name}",
                    f"- Budget share: {matrix.get('budget_share_percent', 0)}%",
                    *[
                        f"- {family.get('family_name', '')} [{family.get('funnel_stage', '')}]: {family.get('angle', '')} | Hypothesis: {family.get('hypothesis', '')}"
                        for family in [*matrix.get("cold_funnel", []), *matrix.get("warm_funnel", [])]
                    ],
                ]
            ],
            "",
            "## Budget And Testing Plan",
            *[
                line
                for phase in plan.get("budget_testing_plan", {}).get("phases", [])
                for line in [
                    f"- {phase.get('phase', '')}: {phase.get('budget_share_percent', 0)}% across {', '.join(phase.get('channels', []))}",
                    *[f"  Hypothesis: {item}" for item in phase.get("hypotheses", [])],
                    *[f"  Success criterion: {item}" for item in phase.get("success_criteria", [])],
                ]
            ],
        ]
    )
    proposal_html = "".join(
        [
            "<html><body>",
            f"<h1>{record.get('brand_name', payload['brand_slug'])} Campaign Proposal</h1>",
            f"<p><strong>Campaign:</strong> {plan.get('campaign_name', '')}</p>",
            f"<p><strong>Objective:</strong> {plan.get('objective', '')}</p>",
            f"<p><strong>Primary CTA:</strong> {plan.get('primary_cta', '')}</p>",
            f"<h2>Audience</h2><p>{plan.get('audience', '')}</p>",
            f"<h2>Positioning</h2><p>{plan.get('positioning', '')}</p>",
            f"<h2>Problem Statement</h2><p>{plan.get('problem_statement', '')}</p>",
            f"<h2>Offer</h2><p>{plan.get('offer', '')}</p>",
            "<h2>Proof Points</h2><ul>",
            *[f"<li>{item}</li>" for item in plan.get("proof_points", [])],
            "</ul><h2>Channel Plans</h2><ul>",
            *[
                f"<li><strong>{channel.get('channel', 'channel')}</strong>: {channel.get('message', '')} (Hook: {channel.get('hook', '')}; CTA: {channel.get('cta', '')}; Hypothesis: {channel.get('hypothesis', '')})</li>"
                for channel in plan.get("channel_plans", [])
            ],
            "</ul><h2>Competitor Context</h2><ul>",
            f"<li><strong>Competitor input:</strong> {plan.get('competitor_context', {}).get('competitor', '')}</li>",
            f"<li><strong>Market positioning:</strong> {plan.get('competitor_context', {}).get('market_positioning', '')}</li>",
            f"<li><strong>Creative takeaway:</strong> {plan.get('competitor_context', {}).get('creative_takeaway', '')}</li>",
            f"<li><strong>Campaign takeaway:</strong> {plan.get('competitor_context', {}).get('campaign_takeaway', '')}</li>",
            *[
                f"<li><strong>Recommended action:</strong> {item}</li>"
                for item in plan.get("competitor_context", {}).get("recommended_actions", [])
            ],
            "</ul><h2>Testing Matrix</h2>",
            *[
                "".join(
                    [
                        f"<h3>{channel_name}</h3>",
                        f"<p><strong>Budget share:</strong> {matrix.get('budget_share_percent', 0)}%</p>",
                        "<ul>",
                        *[
                            f"<li><strong>{family.get('family_name', '')}</strong> [{family.get('funnel_stage', '')}]: {family.get('angle', '')} (Hypothesis: {family.get('hypothesis', '')})</li>"
                            for family in [*matrix.get("cold_funnel", []), *matrix.get("warm_funnel", [])]
                        ],
                        "</ul>",
                    ]
                )
                for channel_name, matrix in plan.get("testing_matrix", {}).items()
            ],
            "<h2>Budget And Testing Plan</h2><ul>",
            *[
                "".join(
                    [
                        f"<li><strong>{phase.get('phase', '')}</strong>: {phase.get('budget_share_percent', 0)}% across {', '.join(phase.get('channels', []))}",
                        "<ul>",
                        *[f"<li>Hypothesis: {item}</li>" for item in phase.get("hypotheses", [])],
                        *[f"<li>Success criterion: {item}</li>" for item in phase.get("success_criteria", [])],
                        "</ul></li>",
                    ]
                )
                for phase in plan.get("budget_testing_plan", {}).get("phases", [])
            ],
            "</ul></body></html>",
        ]
    )
    payload["artifacts"] = {
        "campaign_proposal_markdown_path": write_text(paths["campaign_proposal_md"], proposal_md),
        "campaign_proposal_html_path": write_text(paths["campaign_proposal_html"], proposal_html),
    }
    save_step(run_id, "head_of_marketing", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
