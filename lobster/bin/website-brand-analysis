#!/usr/bin/env python3
import argparse
import os
import json
import re
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _brand_tokens import build_brand_tokens
from _marketing_profile_common import (
    extract_json_object,
    list_of_strings,
    load_json_file,
    normalize_marketing_url,
    normalize_space,
    record_or_empty,
    string_or_none,
    unique_strings,
    utc_now,
    validate_brand_name,
    validate_channel_angles,
    validate_copy_text,
    validate_line_options,
    validate_optional_copy_text,
    validate_short_text,
    validate_unique_copy_list,
    validated_document_path,
    write_json_file,
)
from _stage2_common import (
    emit_json,
    ensure_run_id,
    fetch_text,
    normalize_research_model,
    parse_domain,
    read_stdin_json,
    save_step,
    slugify,
    summarize_with_gemini,
)
from _canonical_outputs import brand_output_paths, write_text


def _tsx_command(repo_root: Path) -> list[str]:
    local_tsx = repo_root / "node_modules" / ".bin" / "tsx"
    if local_tsx.exists():
        return [str(local_tsx)]
    return ["npx", "tsx"]


def _bootstrap_validated_brand_kit(tenant_id: str, website_url: str) -> dict:
    repo_root = Path(__file__).resolve().parents[2]
    command = [
        *_tsx_command(repo_root),
        str(Path(__file__).resolve().parent / "brand-kit-bootstrap.ts"),
        "--tenant-id",
        tenant_id,
        "--brand-url",
        website_url,
    ]
    proc = subprocess.run(
        command,
        text=True,
        capture_output=True,
        check=False,
        cwd=repo_root,
    )
    if proc.returncode != 0:
        message = proc.stderr.strip() or proc.stdout.strip() or "brand_kit_bootstrap_failed"
        raise SystemExit(message)
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"runtime_persistence_unavailable:brand_kit_bootstrap_invalid_json:{exc}") from exc


def _extract_tag_text(html: str, tag_name: str) -> str:
    match = re.search(rf"<{tag_name}[^>]*>(.*?)</{tag_name}>", html, flags=re.IGNORECASE | re.DOTALL)
    return re.sub(r"<[^>]+>", "", match.group(1)).strip() if match else ""


def _extract_meta_content(html: str, attribute_name: str, attribute_value: str) -> str:
    pattern = re.compile(r"<meta\b([^>]*)>", flags=re.IGNORECASE)
    for match in pattern.finditer(html):
        attrs = match.group(1) or ""
        attribute_match = re.search(
            rf'{attribute_name}\s*=\s*["\']{re.escape(attribute_value)}["\']',
            attrs,
            flags=re.IGNORECASE,
        )
        if not attribute_match:
            continue
        content_match = re.search(r'content\s*=\s*["\']([^"\']+)["\']', attrs, flags=re.IGNORECASE)
        if content_match:
            return normalize_space(content_match.group(1))
    return ""


def _load_stage2_site_fixture() -> str:
    inline_html = os.environ.get("LOBSTER_STAGE2_SITE_HTML", "").strip()
    if inline_html:
        return inline_html
    fixture_path = os.environ.get("LOBSTER_STAGE2_SITE_HTML_FIXTURE", "").strip()
    if fixture_path:
        return Path(fixture_path).read_text(encoding="utf-8")
    return ""


def _stage1_competitor_summary(stage1_summary: dict) -> dict:
    identity = record_or_empty(stage1_summary.get("competitorIdentity"))
    locator = record_or_empty(stage1_summary.get("metaLocator"))
    evidence = record_or_empty(stage1_summary.get("evidence"))
    trust = record_or_empty(stage1_summary.get("trustValidation"))
    competitor_url = normalize_marketing_url(
        stage1_summary.get("competitor_url")
        or identity.get("canonicalUrl")
        or stage1_summary.get("competitor")
    )
    return {
        "competitor": stage1_summary.get("competitor", ""),
        "competitor_url": competitor_url,
        "competitorIdentity": {
            "canonicalUrl": competitor_url,
            "canonicalDomain": normalize_space(identity.get("canonicalDomain")),
            "brandName": normalize_space(identity.get("brandName") or stage1_summary.get("competitor")),
            "brandTokens": list_of_strings(identity.get("brandTokens")),
            "trustClassification": normalize_space(identity.get("trustClassification") or trust.get("classification")),
        },
        "metaLocator": {
            "facebookPageUrl": normalize_space(locator.get("facebookPageUrl") or stage1_summary.get("competitor_facebook_url")),
            "adLibraryUrl": normalize_space(locator.get("adLibraryUrl")),
            "metaPageId": normalize_space(locator.get("metaPageId")),
        },
        "evidence": {
            "ctaUrls": list_of_strings(evidence.get("ctaUrls")),
            "ctaDomains": list_of_strings(evidence.get("ctaDomains")),
            "landingPages": list_of_strings(evidence.get("landingPages")),
            "aliasDomains": list_of_strings(evidence.get("aliasDomains")),
            "notes": list_of_strings(evidence.get("notes")),
        },
        "trustValidation": {
            "classification": normalize_space(trust.get("classification")),
            "reasons": list_of_strings(trust.get("reasons")),
            "conflicts": list_of_strings(trust.get("conflicts")),
            "approvedAliasDomains": list_of_strings(trust.get("approvedAliasDomains")),
        },
        "executive_summary": record_or_empty(stage1_summary.get("executive_summary")),
        "recommended_actions": list_of_strings(stage1_summary.get("recommended_actions")),
    }


def _canonical_brand_name(tenant_id: str, website_url: str, brand_kit: dict, website_html: str) -> str:
    title = _extract_tag_text(website_html, "title")
    h1 = _extract_tag_text(website_html, "h1")
    site_name = _extract_meta_content(website_html, "property", "og:site_name") or _extract_meta_content(
        website_html,
        "name",
        "application-name",
    )
    return validate_brand_name(
        site_name or h1 or title or tenant_id,
        canonical_name=brand_kit.get("brand_name") or site_name or h1 or title,
    )


def _structured_analysis_prompt(
    brand_name: str,
    tenant_id: str,
    website_url: str,
    title: str,
    h1: str,
    description: str,
    stage1_summary: dict,
) -> str:
    return "\n".join(
        [
            "Analyze the brand website and return one strict JSON object only.",
            f"Brand name: {brand_name}",
            f"Tenant id: {tenant_id}",
            f"Website URL: {website_url}",
            f"Page title: {title}",
            f"H1: {h1}",
            f"Meta description: {description}",
            f"Competitive context: {json.dumps(stage1_summary, ensure_ascii=True)}",
            "Requirements:",
            "- No markdown.",
            "- No wrapper language.",
            "- No placeholder framing.",
            "- No analysis narration in any field.",
            "- Use finished customer-facing copy for hooks and opening lines.",
            "- Keep proof points specific and non-repeating.",
            "- style_vibe: a short phrase (3-8 words) describing the brand's visual and tonal style derived from the website's color palette, typography, imagery style, layout density, and overall brand personality. Examples: 'Bold and disruptive streetwear energy', 'Warm artisanal with earthy textures', 'Clinical precision with tech-forward optimism'.",
            "- Return this schema exactly:",
            json.dumps(
                {
                    "audience": "string",
                    "positioning": "string",
                    "problem_statement": "string",
                    "offer": "string",
                    "primary_cta": "string",
                    "proof_points": ["string", "string", "string"],
                    "brand_voice": ["string", "string", "string"],
                    "channel_specific_angles": {
                        "meta": "string",
                        "landing-page": "string",
                        "video": "string",
                    },
                    "hooks": {
                        "meta": ["string", "string"],
                        "landing-page": ["string", "string"],
                        "video": ["string", "string"],
                    },
                    "opening_lines": {
                        "meta": ["string"],
                        "landing-page": ["string"],
                        "video": ["string", "string"],
                    },
                    "style_vibe": "string",
                    "business_type": "string or empty",
                    "primary_goal": "string or empty",
                    "launch_approver_name": "string or empty",
                    "channels": ["string", "string"],
                },
                ensure_ascii=True,
            ),
        ]
    )


def _validated_analysis_fields(parsed: dict, brand_name: str) -> dict:
    audience = validate_copy_text("audience", parsed.get("audience"), min_tokens=4)
    positioning = validate_copy_text("positioning", parsed.get("positioning"), min_tokens=4)
    problem_statement = validate_copy_text("problem_statement", parsed.get("problem_statement"), min_tokens=4)
    offer = validate_copy_text("offer", parsed.get("offer"), min_tokens=4)
    primary_cta = validate_copy_text("primary_cta", parsed.get("primary_cta"), min_tokens=2)
    proof_points = validate_unique_copy_list("proof_points", parsed.get("proof_points"), min_items=3, max_items=5, min_tokens=3)
    brand_voice = unique_strings([validate_short_text("brand_voice", item) for item in list_of_strings(parsed.get("brand_voice"))])[:5]
    if len(brand_voice) < 2:
      raise RuntimeError("quality_gate_failed:brand_voice:too_few_items")
    style_vibe = validate_optional_copy_text("style_vibe", parsed.get("style_vibe"), min_tokens=2)
    channel_specific_angles = validate_channel_angles(parsed.get("channel_specific_angles"))
    hooks = validate_line_options(parsed.get("hooks"), "hooks")
    opening_lines = validate_line_options(parsed.get("opening_lines"), "opening_lines")
    return {
        "brand_name": brand_name,
        "audience": audience,
        "positioning": positioning,
        "problem_statement": problem_statement,
        "offer": offer,
        "primary_cta": primary_cta,
        "proof_points": proof_points,
        "brand_voice": brand_voice,
        "channel_specific_angles": channel_specific_angles,
        "hooks": hooks,
        "opening_lines": opening_lines,
        "style_vibe": style_vibe,
        "business_type": validate_optional_copy_text("business_type", parsed.get("business_type"), min_tokens=1),
        "primary_goal": validate_optional_copy_text("primary_goal", parsed.get("primary_goal"), min_tokens=2),
        "launch_approver_name": validate_optional_copy_text("launch_approver_name", parsed.get("launch_approver_name"), min_tokens=1),
        "channels": unique_strings([validate_short_text("channels", item) for item in list_of_strings(parsed.get("channels"))]) if isinstance(parsed.get("channels"), list) else [],
    }


def _structured_from_validated_analysis(existing_analysis: dict) -> dict:
    return {
        "audience": existing_analysis.get("audience") or existing_analysis.get("audience_summary"),
        "positioning": existing_analysis.get("positioning") or existing_analysis.get("positioning_summary"),
        "problem_statement": existing_analysis.get("problem_statement"),
        "offer": existing_analysis.get("offer") or existing_analysis.get("offer_summary"),
        "primary_cta": existing_analysis.get("primary_cta"),
        "proof_points": existing_analysis.get("proof_points"),
        "brand_voice": existing_analysis.get("brand_voice"),
        "channel_specific_angles": existing_analysis.get("channel_specific_angles"),
        "hooks": existing_analysis.get("hooks"),
        "opening_lines": existing_analysis.get("opening_lines"),
        "style_vibe": existing_analysis.get("style_vibe"),
        "business_type": existing_analysis.get("business_type"),
        "primary_goal": existing_analysis.get("primary_goal"),
        "launch_approver_name": existing_analysis.get("launch_approver_name"),
        "channels": existing_analysis.get("channels"),
    }


def _required_brand_token(brand_tokens: dict, section: str, key: str) -> str:
    section_value = record_or_empty(brand_tokens.get(section))
    value = normalize_space(section_value.get(key))
    if not value:
        raise RuntimeError(f"quality_gate_failed:brand_tokens_missing:{section}.{key}")
    return value


def _render_design_system_css(brand_tokens: dict) -> str:
    return "\n".join(
        [
            ":root {",
            f"  color-scheme: {_required_brand_token(brand_tokens, 'palette', 'theme_mode')};",
            f"  --brand-primary: {_required_brand_token(brand_tokens, 'palette', 'primary')};",
            f"  --brand-secondary: {_required_brand_token(brand_tokens, 'palette', 'secondary')};",
            f"  --brand-accent: {_required_brand_token(brand_tokens, 'palette', 'accent')};",
            f"  --brand-bg: {_required_brand_token(brand_tokens, 'palette', 'background')};",
            f"  --brand-surface: {_required_brand_token(brand_tokens, 'palette', 'surface')};",
            f"  --brand-text: {_required_brand_token(brand_tokens, 'palette', 'text')};",
            f"  --brand-muted: {_required_brand_token(brand_tokens, 'palette', 'muted')};",
            f"  --brand-outline: {_required_brand_token(brand_tokens, 'palette', 'outline')};",
            f"  --brand-accent-contrast: {_required_brand_token(brand_tokens, 'palette', 'accent_contrast')};",
            f"  --font-display: {_required_brand_token(brand_tokens, 'typography', 'display_stack')};",
            f"  --font-body: {_required_brand_token(brand_tokens, 'typography', 'body_stack')};",
            "}",
            "",
            "body {",
            "  background: var(--brand-bg);",
            "  color: var(--brand-text);",
            "  font-family: var(--font-body);",
            "}",
        ]
    )


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--website-url", default="")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    parser.add_argument("--stage1-summary-json", default="")
    parser.add_argument("--stage1-summary-base64", default="")
    parser.add_argument("--strict-mode", default="true")
    args = parser.parse_args()

    if args.stage1_summary_base64.strip():
        import base64

        raw_stage1_summary = base64.b64decode(args.stage1_summary_base64).decode("utf-8")
        stage1_summary = json.loads(raw_stage1_summary)
    elif args.stage1_summary_json.strip():
        raw_stage1_summary = args.stage1_summary_json.strip()
        stage1_summary = json.loads(raw_stage1_summary)
    else:
        stage1_summary = read_stdin_json()

    tenant_id = normalize_space(args.brand_slug or stage1_summary.get("tenant_id") or stage1_summary.get("brand_slug"))
    if not tenant_id:
        raise SystemExit("stage2_live_strategy_input_required:tenant_id_missing")

    website_url = normalize_marketing_url(args.website_url.strip() or stage1_summary.get("website_url", ""))
    if not website_url:
        raise SystemExit("stage2_live_strategy_input_required:website_url_missing")

    brand_slug = slugify(tenant_id)
    research_model = normalize_research_model(args.research_model or stage1_summary.get("research_model", ""))
    run_id = ensure_run_id(stage1_summary.get("run_id", ""), tenant_id, website_url)
    strict_mode = args.strict_mode.strip().lower() in {"1", "true", "yes", "y", "on"}

    brand_kit_bootstrap = _bootstrap_validated_brand_kit(tenant_id, website_url)
    brand_kit_path = validated_document_path(tenant_id, "brand-kit.json")
    brand_kit = load_json_file(brand_kit_path)
    if not brand_kit:
        raise SystemExit("runtime_persistence_unavailable:brand_kit_missing")
    brand_tokens = build_brand_tokens(brand_kit)

    website_html = _load_stage2_site_fixture()
    if not website_html:
        try:
            website_html = fetch_text(website_url, timeout=20.0, headers={"User-Agent": "lobster-stage2/2.0"})
        except Exception as exc:
            raise SystemExit(f"stage2_live_strategy_input_required:website_fetch_failed:{type(exc).__name__}:{exc}") from exc

    title = _extract_tag_text(website_html, "title")
    h1 = _extract_tag_text(website_html, "h1")
    description = _extract_meta_content(website_html, "name", "description")
    brand_name = _canonical_brand_name(tenant_id, website_url, brand_kit, website_html)
    existing_validated_website_analysis = load_json_file(validated_document_path(tenant_id, "website-analysis.json"))
    existing_brand_analysis = record_or_empty(existing_validated_website_analysis.get("brand_analysis"))
    stage1_competitor_summary = _stage1_competitor_summary(stage1_summary)
    prompt = _structured_analysis_prompt(
        brand_name=brand_name,
        tenant_id=tenant_id,
        website_url=website_url,
        title=title,
        h1=h1,
        description=description,
        stage1_summary=stage1_competitor_summary,
    )
    gemini = summarize_with_gemini(prompt=prompt, research_model=research_model)
    reused_validated_analysis = False
    if gemini.get("live"):
        structured = extract_json_object(gemini.get("text", ""))
        if not structured:
            raise SystemExit("quality_gate_failed:website_analysis:invalid_json")
    else:
        existing_website_url = normalize_marketing_url(existing_brand_analysis.get("website_url") or existing_brand_analysis.get("canonical_url"))
        if existing_brand_analysis and existing_website_url == website_url:
            structured = _structured_from_validated_analysis(existing_brand_analysis)
            reused_validated_analysis = True
        elif strict_mode:
            raise SystemExit("stage2_live_strategy_input_required:gemini_analysis_unavailable")
        else:
            structured = {}
    if not structured:
        raise SystemExit("quality_gate_failed:website_analysis:invalid_json")

    validated_fields = _validated_analysis_fields(structured, brand_name)
    canonical_url = normalize_marketing_url(brand_kit.get("canonical_url") or website_url) or website_url
    competitor_url = stage1_competitor_summary["competitor_url"] or None

    brand_analysis = {
        "tenant_id": tenant_id,
        "brand_name": brand_name,
        "brand_slug": brand_slug,
        "website_url": website_url,
        "canonical_url": canonical_url,
        "domain": parse_domain(canonical_url),
        "homepage_signals": {
            "title": title or brand_name,
            "h1": h1 or brand_name,
            "description": description,
        },
        "brand_promise": validated_fields["hooks"]["landing-page"][0],
        "audience": validated_fields["audience"],
        "audience_summary": validated_fields["audience"],
        "positioning": validated_fields["positioning"],
        "positioning_summary": validated_fields["positioning"],
        "problem_statement": validated_fields["problem_statement"],
        "offer": validated_fields["offer"],
        "offer_summary": validated_fields["offer"],
        "primary_cta": validated_fields["primary_cta"],
        "cta_preferences": [validated_fields["primary_cta"]],
        "proof_points": validated_fields["proof_points"],
        "brand_voice": validated_fields["brand_voice"],
        "channel_specific_angles": validated_fields["channel_specific_angles"],
        "hooks": validated_fields["hooks"],
        "opening_lines": validated_fields["opening_lines"],
        "business_type": validated_fields["business_type"],
        "primary_goal": validated_fields["primary_goal"],
        "launch_approver_name": validated_fields["launch_approver_name"],
        "channels": validated_fields["channels"],
        "style_vibe": validated_fields.get("style_vibe"),
        "competitor_url": competitor_url,
        "brand_kit": {
            "brand_name": brand_kit.get("brand_name"),
            "source_url": brand_kit.get("source_url"),
            "canonical_url": brand_kit.get("canonical_url"),
            "colors": record_or_empty(brand_kit.get("colors")),
            "font_families": list_of_strings(brand_kit.get("font_families")),
            "logo_urls": list_of_strings(brand_kit.get("logo_urls")),
            "extracted_at": string_or_none(brand_kit.get("extracted_at")),
        },
        "design_tokens": brand_tokens,
        "stage1_summary": {
            **stage1_competitor_summary,
        },
    }

    paths = brand_output_paths(brand_slug)
    brand_bible_md = "\n".join(
        [
            f"# {brand_name} Brand Bible",
            "",
            f"- Tenant id: {tenant_id}",
            f"- Website: {website_url}",
            f"- Primary CTA: {brand_analysis['primary_cta']}",
            "",
            "## Audience",
            brand_analysis["audience"],
            "",
            "## Positioning",
            brand_analysis["positioning"],
            "",
            "## Problem Statement",
            brand_analysis["problem_statement"],
            "",
            "## Offer",
            brand_analysis["offer"],
            "",
            "## Proof Points",
            *[f"- {point}" for point in brand_analysis["proof_points"]],
            "",
            "## Channel Angles",
            *[f"- {channel}: {angle}" for channel, angle in brand_analysis["channel_specific_angles"].items()],
            "",
            "## Hooks",
            *[
                f"- {channel}: {' | '.join(lines)}"
                for channel, lines in brand_analysis["hooks"].items()
            ],
            "",
            "## Opening Lines",
            *[
                f"- {channel}: {' | '.join(lines)}"
                for channel, lines in brand_analysis["opening_lines"].items()
            ],
        ]
    )
    design_system_css = _render_design_system_css(brand_tokens)
    brand_bible_path = write_text(paths["brand_bible_md"], brand_bible_md)
    design_system_path = write_text(paths["design_system_css"], design_system_css)

    validated_payload = {
        "schema_version": "2026-03-31.website-analysis.v1",
        "type": "website_analysis",
        "tenant_id": tenant_id,
        "brand_slug": brand_slug,
        "brand_name": brand_name,
        "website_url": website_url,
        "canonical_url": canonical_url,
        "source_run_id": run_id,
        "validated_at": utc_now(),
        "research_model": research_model,
        "brand_analysis": brand_analysis,
        "research": {
            "website_fetch": {
                "live": True,
                "error": "",
            },
            "gemini": gemini,
            "brand_kit_bootstrap": brand_kit_bootstrap,
            "validated_website_analysis_reuse": {
                "used": reused_validated_analysis,
                "path": str(validated_document_path(tenant_id, "website-analysis.json")) if reused_validated_analysis else "",
            },
        },
    }
    validated_website_analysis_path = write_json_file(
        validated_document_path(tenant_id, "website-analysis.json"),
        validated_payload,
    )

    payload = {
        "type": "website_brand_analysis",
        "stub": False,
        "mode": "live",
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "tenant_id": tenant_id,
        "brand_slug": brand_slug,
        "website_url": website_url,
        "validated_website_analysis_path": validated_website_analysis_path,
        "brand_analysis": brand_analysis,
        "research": validated_payload["research"],
        "artifacts": {
            "brand_bible_markdown_path": brand_bible_path,
            "design_system_css_path": design_system_path,
            "design_token_source_path": str(brand_kit_path),
        },
        "persistence": {
            "backend": "runtime-validated-store",
            "validated_website_analysis_path": validated_website_analysis_path,
            "brand_kit_path": str(brand_kit_path),
            "brand_kit_bootstrap_action": brand_kit_bootstrap.get("bootstrap_action", ""),
            "design_token_source": "validated_brand_kit",
        },
    }
    save_step(run_id, "website_brand_analysis", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
