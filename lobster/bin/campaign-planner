#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _marketing_profile_common import record_or_empty, validate_copy_text
from _stage2_common import emit_json, ensure_run_id, normalize_research_model, read_stdin_json, save_step, utc_now


def _channel_plans(creative_handoff: dict, channel_contexts: dict) -> list[dict]:
    plans = []
    for channel in ("meta", "landing-page", "video"):
        context = record_or_empty(channel_contexts.get(channel))
        plans.append(
            {
                "channel": channel,
                "goal": validate_copy_text(f"campaign_plan.{channel}.goal", context.get("angle") or creative_handoff["channel_specific_angles"][channel], min_tokens=4),
                "message": creative_handoff["channel_specific_angles"][channel],
                "hook": creative_handoff["hooks"][channel][0],
                "opening_line": creative_handoff["opening_lines"][channel][0],
                "cta": creative_handoff["primary_cta"],
                "creative_bias": context.get("creative_bias", ""),
            }
        )
    return plans


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--brand-slug", default="client-brand")
    parser.add_argument("--research-model", default="gemini/gemini-3-flash-preview")
    args = parser.parse_args()

    data = read_stdin_json()
    record = record_or_empty(data.get("brand_profiles_record"))
    creative_handoff = record_or_empty(data.get("creative_handoff") or record.get("creative_handoff"))
    channels = record_or_empty(data.get("downstream_channel_context"))
    if not creative_handoff:
        raise SystemExit("quality_gate_failed:creative_handoff:missing")

    run_id = ensure_run_id(data.get("run_id", ""), record.get("tenant_id", ""), args.brand_slug)
    research_model = normalize_research_model(args.research_model or data.get("research_model", ""))
    primary_cta = creative_handoff.get("primary_cta", "")
    proof_points = creative_handoff.get("proof_points", [])[:3]
    campaign_name = f"{record.get('brand_slug', args.brand_slug)}-stage2-plan"
    plan = {
        "campaign_name": campaign_name,
        "objective": f"Turn the validated {record.get('brand_name', 'brand')} analysis into differentiated paid, page, and video creative.",
        "core_message": creative_handoff["hooks"]["landing-page"][0],
        "audience": creative_handoff["audience"],
        "positioning": creative_handoff["positioning"],
        "problem_statement": creative_handoff["problem_statement"],
        "offer": creative_handoff["offer"],
        "primary_cta": primary_cta,
        "proof_points": proof_points,
        "channel_plans": _channel_plans(creative_handoff, channels),
    }

    payload = {
        "type": "campaign_planner",
        "stub": False,
        "mode": "live",
        "generated_at": utc_now(),
        "run_id": run_id,
        "research_model": research_model,
        "brand_slug": record.get("brand_slug", args.brand_slug),
        "campaign_plan": plan,
        "brand_profiles_record": record,
        "creative_handoff": creative_handoff,
        "downstream_channel_context": channels,
    }
    save_step(run_id, "campaign_planner", payload)
    emit_json(payload)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
