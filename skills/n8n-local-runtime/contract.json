{
  "skill": "n8n-local-runtime",
  "version": "1.0.0",
  "runtime": {
    "baseUrl": "http://localhost:5678",
    "environment": "local macOS test instance",
    "projectRootEnv": {
      "name": "PROJECT_ROOT",
      "value": "$HOME/.openclaw/workspace/aries-platform-bootstrap"
    }
  },
  "constraints": {
    "allowedNodeTypes": [
      "n8n-nodes-base.webhook",
      "n8n-nodes-base.set",
      "n8n-nodes-base.if",
      "n8n-nodes-base.executeCommand",
      "n8n-nodes-base.httpRequest",
      "n8n-nodes-base.respondToWebhook"
    ],
    "maxRepairAttempts": 3,
    "patchPolicy": {
      "mode": "section-only",
      "allow": [
        "single node payload",
        "single connection branch",
        "single activation/import compatibility flag"
      ],
      "deny": [
        "full workflow redesign",
        "rewriting validated generator artifacts",
        "rewriting validated validator artifacts",
        "node type outside allowlist"
      ]
    }
  },
  "workflowCompatibility": {
    "mustMatchLocalExportStructure": true,
    "strategy": [
      "fetch or export a known-good local workflow",
      "mirror top-level shape and compatibility fields",
      "reuse observed field conventions before inventing schema"
    ]
  },
  "publishFlow": {
    "steps": [
      {
        "name": "import_or_create",
        "endpoint": "/rest/workflows",
        "method": "POST",
        "capture": ["httpStatus", "responseBody"]
      },
      {
        "name": "activate",
        "endpointTemplate": "/rest/workflows/{id}",
        "method": "PATCH",
        "body": { "active": true },
        "capture": ["httpStatus", "responseBody"]
      }
    ],
    "errorHandling": {
      "onImportError": "capture -> isolate failing section -> patch only that section -> retry",
      "onActivationError": "capture -> isolate failing section -> patch only that section -> retry",
      "retryLimit": 3,
      "reportOnExhaustedRetries": [
        "stage",
        "lastHttpStatus",
        "lastErrorBody",
        "patchedSections"
      ]
    }
  }
}
