6:["$","div",null,{"className":"doc-content","children":[["$","h2",null,{"id":"overview","children":"Overview"}],["$","p",null,{"children":"Aries AI is a multi-tenant platform that orchestrates AI-powered content pipelines across 7 social platforms. Built on Next.js 15 and n8n, it provides end-to-end automation from research and strategy through production, approval, and publishing."}],["$","p",null,{"children":"The system uses a workflow-first architecture: every operation — from onboarding a new tenant to publishing a scheduled post — is modeled as an n8n workflow with built-in repair, retry, and observability."}],["$","h2",null,{"id":"quickstart","children":"Quick Start"}],["$","h3",null,{"children":"Prerequisites"}],["$","ul",null,{"children":[["$","li",null,{"children":"Node.js 18+ and npm"}],["$","li",null,{"children":"A running n8n instance with API access"}],["$","li",null,{"children":"Platform OAuth credentials (Meta, LinkedIn, X, etc.)"}]]}],["$","h3",null,{"children":"Environment Setup"}],["$","div",null,{"className":"code-block","children":["$","code",null,{"children":"# Clone and install\ngit clone <repo-url> && cd aries-app\nnpm install\n\n# Configure environment\ncp .env.example .env\n# Edit .env with your N8N_BASE_URL and N8N_API_KEY\n\n# Start development server\nnpm run dev"}]}],["$","h3",null,{"children":"First Steps"}],["$","ol",null,{"children":[["$","li",null,{"children":"Verify your n8n connection by checking the dashboard"}],["$","li",null,{"children":"Connect at least one platform via Settings → Platforms"}],["$","li",null,{"children":"Create your first marketing job from the Posts page"}],["$","li",null,{"children":"Monitor progress in the Dashboard"}]]}],["$","h2",null,{"id":"architecture","children":"Architecture"}],["$","p",null,{"children":"Aries follows a layered architecture with clear boundaries:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Frontend Layer"}]," — React components, app-shel