# Runtime shell examples (do not put real secrets here)

# App runtime
NODE_ENV=production
PORT=3000
CODE_ROOT=/app
DATA_ROOT=/data
ARIES_APP_IMAGE=aries-app:local
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:3456
OPENCLAW_GATEWAY_TOKEN=replace-with-your-openclaw-gateway-token
OPENCLAW_SESSION_KEY=main
OPENCLAW_LOBSTER_CWD=lobster

# External Postgres (required)
DB_HOST=your-cloud-postgres-host
DB_PORT=5432
DB_USER=your-postgres-user
DB_PASSWORD=your-postgres-password
DB_NAME=your-postgres-database

# Internal API secret for trusted workflow runners that create runtime artifacts.
INTERNAL_API_SECRET=your-internal-callback-secret

# App base URL
APP_BASE_URL=https://your-app.example.com

# Google OAuth / NextAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_URL=https://your-app.example.com
AUTH_URL=https://your-app.example.com
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Meta / Facebook integration
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# OAuth callback URIs (register in each provider console)
GOOGLE_REDIRECT_URI=https://your-app.example.com/api/auth/oauth/callback/google
META_REDIRECT_URI=https://your-app.example.com/api/auth/oauth/callback/meta
LINKEDIN_REDIRECT_URI=https://your-app.example.com/api/auth/oauth/callback/linkedin
TIKTOK_REDIRECT_URI=https://your-app.example.com/api/auth/oauth/callback/tiktok
X_REDIRECT_URI=https://your-app.example.com/api/auth/oauth/callback/x
YOUTUBE_REDIRECT_URI=https://your-app.example.com/api/auth/oauth/callback/youtube

# Optional diagnostics
LOG_LEVEL=info
