# Runtime shell examples (do not put real secrets here)

# App runtime
NODE_ENV=development
PORT=3000
PROJECT_ROOT=/path/to/aries-app

# n8n connection (required)
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_API_KEY=your-n8n-api-key-here

# App base URL
APP_BASE_URL=https://your-app.example.com

# Meta / Facebook integration
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://your-app.example.com/api/integrations/meta/callback

# Optional diagnostics
LOG_LEVEL=info
