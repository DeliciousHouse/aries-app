# Runtime shell examples (do not put real secrets here)

# App runtime
NODE_ENV=development
PORT=3000
PROJECT_ROOT=/Users/you/.openclaw/workspace/aries-platform-bootstrap

# Local n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=replace_with_local_n8n_api_key

# Optional diagnostics
LOG_LEVEL=info
