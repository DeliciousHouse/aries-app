# Runtime shell examples (do not put real secrets here)

# App runtime
NODE_ENV=production
PORT=3000
CODE_ROOT=/app
DATA_ROOT=/data
MARKETING_STATUS_PUBLIC=0
ARIES_APP_IMAGE=aries-app:local
ARIES_EXECUTION_PROVIDER=hermes
ARIES_MARKETING_EXECUTION_PROVIDER=hermes

# Hermes-native weekly social content execution.
# APP_BASE_URL and INTERNAL_API_SECRET are required for Hermes callbacks.
HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_API_SERVER_KEY=replace-with-the-value-of-API_SERVER_KEY-from-your-hermes-env
HERMES_SESSION_KEY=main
# How long Aries waits for a Hermes run to reach a terminal status before
# recording `hermes_gateway_timeout`. 1200000ms (20 min) is calibrated to
# real one-off campaigns (production stage with 7 image renders runs ~10-11
# min). Raise for tenants with video-render workloads; lower carefully.
HERMES_RUN_TIMEOUT_MS=1200000
# Poll interval against the Hermes gateway while waiting for completion.
# Empty = code default (1000ms). Tighter polling is rarely useful.
HERMES_POLL_INTERVAL_MS=

# Phase B three-profile routing. Each marketing stage runs on a dedicated
# Hermes profile bound to its own gateway port. Every var below falls back to
# HERMES_GATEWAY_URL / HERMES_API_SERVER_KEY when left blank, so a single-
# gateway deployment can ignore all six.
#   research stage            -> aries-research          (default gateway,
#                                port 8642 — the aries-research gateway is
#                                127.0.0.1-bound and not container-reachable,
#                                so research stays on the default gateway)
#   strategy + publish stages -> aries-strategist        (gateway port 8654)
#   production stage          -> aries-content-generator (gateway port 8655)
# docker-compose.yml ships the strategist/content cutover defaults; leave
# these blank locally to keep the single-gateway behavior.
HERMES_RESEARCH_GATEWAY_URL=
HERMES_RESEARCH_API_SERVER_KEY=
HERMES_STRATEGIST_GATEWAY_URL=
HERMES_STRATEGIST_API_SERVER_KEY=
HERMES_CONTENT_GATEWAY_URL=
HERMES_CONTENT_API_SERVER_KEY=
# Onboarding brand-identity LLM enrichment via Hermes (Gemini). Off by default;
# set to 1 once the analyze_brand_identity Hermes session config is in place.
# Optional overrides: HERMES_BRAND_ANALYSIS_SESSION_KEY, HERMES_BRAND_ANALYSIS_TIMEOUT_MS.
ARIES_BRAND_ENRICHMENT_ENABLED=0

# Hermes kanban GC worker (archives completed tasks + runs `hermes kanban gc`).
# Enabled by default; set to 0 to disable. Interval in ms (default 24 h).
ARIES_KANBAN_GC_ENABLED=1
ARIES_KANBAN_GC_INTERVAL_MS=86400000
ARIES_KANBAN_GC_RETENTION_DAYS=7

# Tenant memory (Honcho) + Hermes `aries-research` bridge (see docs/plans/2026-05-08-aries-hermes-honcho-architecture.md).
# Local/dev: point Aries at Honcho on the host. Production: restrict Honcho network + AUTH_USE_AUTH=true before enabling research.
HONCHO_BASE_URL=http://host.docker.internal:8000
# Control-plane JWT for Honcho workspace lifecycle only (not routine memory reads/writes once data-plane minting ships).
HONCHO_CONTROL_PLANE_JWT=replace-with-honcho-control-plane-jwt
# Optional workspace-scoped JWT for routine tenant memory reads/writes (messages, lists). When unset, control-plane JWT is used for all Honcho calls (dev only).
HONCHO_DATA_PLANE_JWT=

# When HONCHO_ENABLED=true, mirror strategy approvals and job denials to Honcho (Phase 1).
HONCHO_WRITE_APPROVALS_ENABLED=
# Phase 2: publish verification, scheduled posts, Hermes publish performance → Honcho
HONCHO_WRITE_PUBLISH_ENABLED=
# Phase 3: explicit operator creative voice/style preference toggle → Honcho
HONCHO_WRITE_PREFERENCES_ENABLED=

# Phase 4 (PR1): Slack Events API signing secret. Required for the inbound
# webhook at POST /api/integrations/slack/events. Without it, the route
# returns 503 (handshake will fail). Same value as the "Signing Secret"
# under "Basic Information" in the Slack app admin.
SLACK_SIGNING_SECRET=
# 16+ chars; rotates tenant workspace pseudonyms if changed.
ARIES_TENANT_PSEUDONYM_SALT=replace-with-32-plus-char-secret-minimum-sixteen
# Set to 1 when Hermes exposes the aries-research webhook and Honcho is reachable. Marketing research stage submits a bounded job + memoryContext.
ARIES_RESEARCH_ENABLED=0
# Optional: cap assembled memoryContext size (orchestrator token budget heuristic).
# ARIES_RESEARCH_MEMORY_TOKEN_BUDGET=4096
# Hermes HTTP entry that accepts POST { jobId, taskSpec, tenantPseudonym, memoryContext, callbackUrl, callbackToken } (API key auth).
HERMES_RESEARCH_WEBHOOK_URL=https://your-hermes-host.example.com/v1/webhooks/aries-research
# Profile name on the Hermes side (documentation / routing; optional if the webhook is already scoped).
HERMES_RESEARCH_AGENT_NAME=aries-research
# Hermes must call /api/internal/aries-research/callback with Authorization: Bearer matching INTERNAL_API_SECRET above (same value in Hermes env if you do not split secrets).

# External Postgres (required)
DB_HOST=your-cloud-postgres-host
DB_PORT=5432
DB_USER=your-postgres-user
DB_PASSWORD=your-postgres-password
DB_NAME=your-postgres-database

# Internal API secret for trusted workflow runners that create runtime artifacts.
INTERNAL_API_SECRET=your-internal-callback-secret

# App base URL
APP_BASE_URL=https://your-app.example.com

# Google OAuth / NextAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_URL=https://your-app.example.com
AUTH_URL=https://your-app.example.com
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# VMS partner attribution (optional). When PARTNER_ATTRIBUTION_ENABLED=true, Aries stores ?ref= on signup
# and POSTs new users to VMS /api/aries/signup. VMS_WEBHOOK_SECRET must match VMS ARIES_WEBHOOK_SECRET.
# Generate a shared secret: openssl rand -hex 32
PARTNER_ATTRIBUTION_ENABLED=false
VMS_BASE_URL=http://vms-app:3000
VMS_WEBHOOK_SECRET=
# Optional: separate signing key for the HttpOnly partner-ref cookie (defaults to NEXTAUTH_SECRET).
# PARTNER_REF_COOKIE_SECRET=

# Weekly social content integration requirements:
# - Hermes owns ChatGPT/OpenAI auth for weekly image/video generation.
# - Text planning can run when media generation is disabled.
# - Generic Aries OAuth integrations still require a stable
#   OAUTH_TOKEN_ENCRYPTION_KEY. Generate the encryption key with:
#     openssl rand -base64 32

# Meta configuration
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_PAGE_ID=your-meta-page-id
META_AD_ACCOUNT_ID=your-meta-ad-account-id
META_ACCESS_TOKEN=your-meta-access-token

# Provider OAuth clients
OAUTH_TOKEN_ENCRYPTION_KEY=replace-with-base64-32-byte-key-generated-by-openssl-rand-base64-32
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=AriesOAuthBroker/1.0

# Register these callback URLs in each provider console.
# Aries builds them from APP_BASE_URL at runtime:
#   https://your-app.example.com/api/auth/oauth/facebook/callback
#   https://your-app.example.com/api/auth/oauth/linkedin/callback
#   https://your-app.example.com/api/auth/oauth/reddit/callback
#   https://your-app.example.com/api/auth/oauth/tiktok/callback
#   https://your-app.example.com/api/auth/oauth/x/callback
#   https://your-app.example.com/api/auth/oauth/youtube/callback
#
# Meta publishing remains env-managed with META_PAGE_ID and META_ACCESS_TOKEN.

# Transactional email (password reset flow) — Resend https://resend.com
# Free tier: 100 emails/day, 3000/month. The Resend Node SDK reads
# RESEND_API_KEY directly from process.env — don't rename it.
#
# BOTH variables are required in production. Common failure modes:
#
#   1. RESEND_API_KEY missing or empty:
#      lib/email.ts logs at ERROR and skips the send. /forgot-password still
#      returns 200 (no enumeration oracle) — so the user gets no email and
#      the flow appears broken with no client-side signal. Check the server
#      logs for "[email] RESEND_API_KEY is not set".
#
#   2. EMAIL_FROM domain not DNS-verified in Resend:
#      Resend returns a 4xx we log as "Resend returned an error". The domain
#      in EMAIL_FROM must be added + verified at https://resend.com/domains
#      BEFORE it will accept sends from it. Verification requires a TXT +
#      DKIM/MX record; usually takes < 15 min. For local/staging testing
#      without a verified domain, use Resend's shared sandbox sender:
#        EMAIL_FROM=Aries AI <onboarding@resend.dev>
#
#   3. Rate limit (default 5 req/sec per team) — surfaces as 429.
#
# Create an API key at https://resend.com/api-keys (starts with `re_`).
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Aries AI <noreply@your-app.example.com>

# Optional diagnostics
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Marketing stage-cache artifact paths (optional)
# Aries reads generated stage artifacts from these cache roots. Defaults are
# resolved under DATA_ROOT when unset.
# ---------------------------------------------------------------------------
# ARTIFACT_STAGE1_CACHE_DIR=/data/hermes-stage1-cache
# ARTIFACT_STAGE2_CACHE_DIR=/data/hermes-stage2-cache
# ARTIFACT_STAGE3_CACHE_DIR=/data/hermes-stage3-cache
# ARTIFACT_STAGE4_CACHE_DIR=/data/hermes-stage4-cache

# PR #302 migration gate. Set to 1 to allow READ from the legacy
# <cacheRoot>/<runId>/... layout that predates tenant-scoped paths. New
# writes always go to <cacheRoot>/<tenantId>/<runId>/... regardless of
# this flag.
# ARIES_STAGE_CACHE_LEGACY_READ_FALLBACK=1
# GEMINI_API_KEY=your-gemini-api-key
