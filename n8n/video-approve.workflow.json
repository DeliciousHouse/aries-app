    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, finalStatus: 'rejected', approval: { status: 'rejected', rejectedAt: new Date().toISOString(), reason: $json.reason || 'No reason provided' } } }];"
      },
      "id": "rejectVideo",
      "name": "Reject Video",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 360]
    }
  ],
  "connections": {
