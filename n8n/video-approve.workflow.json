      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [420, 280]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, finalStatus: 'accepted', approval: { status: 'approved', approvedAt: new Date().toISOString() } } }];"
      },
      "id": "acceptVideo",
