          },
          "conditions": [
            {
              "leftValue": "={{$json.approvalDecision}}",
              "rightValue": "approved",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "ifApproved",
