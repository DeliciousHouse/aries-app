{
  "artifact_name": "marketing_publish_workflow",
  "artifact_type": "n8n_workflow_spec",
  "schema_version": "1.0.0",
  "target": "self-hosted-n8n",
  "workflow_file": "./n8n/marketing-publish.workflow.json",
  "trigger": {
    "type": "webhook",
    "path": "marketing-publish",
    "method": "POST",
    "response_mode": "responseNode"
  },
  "inputs": [
    "tenant_id",
    "job_type",
    "request.production_outputs",
    "request.publish_targets",
    "request.dry_run"
  ],
  "shared_schemas": [
    "./specs/tenant_runtime_state_schema.v1.json",
    "./specs/job_runtime_state_schema.v1.json"
  ],
  "contract_reference": "./specs/marketing_job_contract_spec.v1.json",
  "steps": [
    "normalize_input",
    "validate_required_input",
    "assert_shared_schemas_exist_and_parse",
    "publish_with_safe_defaults_paused",
    "persist_structured_publish_results",
    "respond_structured_json"
  ],
  "safety_defaults": {
    "publish_state_default": "paused",
    "activate_after_publish": false,
    "dry_run_default": true
  },
  "stage_transitions": [
    "queued",
    "validating_inputs",
    "publishing",
    "publish_completed"
  ],
  "bounded_repair": {
    "enabled": true,
    "max_attempts": 3,
    "policy": "repair only malformed publish_targets and missing optional request fields; do not fabricate missing production outputs"
  },
  "outputs": {
    "success_fields": [
      "status",
      "tenant_id",
      "job_type",
      "job_id",
      "publish_state",
      "results_path",
      "targets"
    ],
    "error_fields": [
      "status",
      "reason",
      "code",
      "details"
    ]
  },
  "allowed_node_types_reference": "./skills/n8n-local-runtime/contract.json"
}
