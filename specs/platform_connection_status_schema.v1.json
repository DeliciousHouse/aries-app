{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aries-platform-bootstrap/specs/platform_connection_status_schema.v1.json",
  "title": "platform_connection_status_schema.v1",
  "description": "Tenant-scoped contract for normalized external platform connection status.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "tenant_id",
    "platform",
    "connection_status",
    "updated_at"
  ],
  "properties": {
    "schema_name": {
      "const": "platform_connection_status_schema"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "tenant_id": {
      "$ref": "#/$defs/tenant_id"
    },
    "integration_id": {
      "$ref": "#/$defs/integration_id"
    },
    "platform": {
      "$ref": "#/$defs/platform"
    },
    "connection_status": {
      "$ref": "#/$defs/connection_status"
    },
    "status_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "health": {
      "$ref": "#/$defs/health_status"
    },
    "last_success_at": {
      "$ref": "#/$defs/timestamp"
    },
    "last_error": {
      "$ref": "#/$defs/error_info"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "uniqueItems": true,
      "default": []
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "updated_at": {
      "$ref": "#/$defs/timestamp"
    }
  },
  "$defs": {
    "tenant_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,61}$"
    },
    "integration_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{1,127}$"
    },
    "platform": {
      "type": "string",
      "enum": [
        "facebook",
        "instagram",
        "linkedin",
        "x",
        "youtube",
        "reddit",
        "tiktok"
      ]
    },
    "connection_status": {
      "type": "string",
      "enum": [
        "disconnected",
        "pending_oauth",
        "oauth_authorized",
        "credential_validating",
        "connected",
        "degraded",
        "token_expired",
        "revoked",
        "permission_denied",
        "misconfigured",
        "rate_limited",
        "error"
      ]
    },
    "health_status": {
      "type": "string",
      "enum": [
        "unknown",
        "healthy",
        "degraded",
        "unhealthy"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "error_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        },
        "at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      },
      "default": {}
    }
  }
}
