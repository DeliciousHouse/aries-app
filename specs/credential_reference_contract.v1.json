{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aries-platform-bootstrap/specs/credential_reference_contract.v1.json",
  "artifact_name": "credential_reference_contract",
  "artifact_type": "security_reference_contract",
  "schema_version": "1.0.0",
  "contract_scope": "indirect_secret_reference_for_token_and_session_artifacts",
  "compatibility_statement": {
    "validated_v2_1_bootstrap_artifacts_unchanged": true,
    "non_breaking_addition_only": true,
    "disallowed_changes": [
      "auth_response_shapes",
      "backend_error_shapes",
      "runtime_enums"
    ]
  },
  "reference_object_contract": {
    "object_name": "CredentialReference",
    "required_fields": [
      "reference_id",
      "reference_type",
      "provider",
      "tenant_scope",
      "lifecycle_state",
      "created_at",
      "updated_at"
    ],
    "optional_fields": [
      "key_purpose",
      "algorithm_family",
      "not_before",
      "expires_at",
      "rotation_group",
      "version",
      "resolution_hint",
      "attestation"
    ],
    "field_definitions": {
      "reference_id": {
        "type": "string",
        "pattern": "^cr_[a-z0-9]{12,64}$",
        "description": "Opaque handle only; no secret material."
      },
      "reference_type": {
        "enum": [
          "key_encryption_key",
          "hmac_secret",
          "signing_key",
          "certificate",
          "api_client_secret"
        ]
      },
      "provider": {
        "enum": [
          "internal_hsm",
          "cloud_kms",
          "secret_manager",
          "vault"
        ]
      },
      "tenant_scope": {
        "enum": [
          "global",
          "tenant",
          "service"
        ]
      },
      "lifecycle_state": {
        "enum": [
          "active",
          "rotating",
          "retired",
          "revoked"
        ]
      },
      "resolution_hint": {
        "type": "string",
        "max_length": 256,
        "must_not_include": [
          "plaintext_secret",
          "private_key",
          "password"
        ]
      },
      "attestation": {
        "type": "object",
        "required_fields": [
          "integrity_level",
          "last_verified_at"
        ],
        "integrity_level_enum": [
          "unverified",
          "verified",
          "hardware_backed"
        ]
      }
    }
  },
  "usage_contract": {
    "allowed_bindings": [
      {
        "artifact": "refresh_token",
        "required_reference_types": [
          "key_encryption_key",
          "hmac_secret"
        ]
      },
      {
        "artifact": "session_id",
        "required_reference_types": [
          "hmac_secret"
        ]
      },
      {
        "artifact": "access_token",
        "required_reference_types": [
          "signing_key"
        ]
      }
    ],
    "reference_resolution_rules": {
      "must_resolve_to_single_active_version": true,
      "must_be_tenant_consistent": true,
      "allow_global_fallback_only_if_explicit": true
    }
  },
  "rotation_contract": {
    "rotation_metadata_required": true,
    "version_monotonic_increase_required": true,
    "overlap_window_seconds_max": 3600,
    "post_rotation_requirements": [
      "new_references_used_for_new_issuance",
      "old_references_allowed_only_within_overlap_window",
      "retired_reference_rejected_after_overlap"
    ]
  },
  "audit_contract": {
    "required_audit_events": [
      "credential_reference.created",
      "credential_reference.updated",
      "credential_reference.rotated",
      "credential_reference.revoked",
      "credential_reference.resolved"
    ],
    "required_audit_fields": [
      "event_type",
      "occurred_at",
      "reference_id",
      "reference_type",
      "tenant_id",
      "actor_id",
      "correlation_id"
    ],
    "minimum_retention_days": 30,
    "redaction_required_fields": [
      "resolution_hint",
      "provider_internal_path"
    ]
  },
  "security_constraints": {
    "forbidden_fields_anywhere": [
      "plaintext_secret",
      "private_key_pem",
      "raw_key_bytes",
      "password"
    ],
    "api_response_policy": {
      "reference_object_may_be_returned": true,
      "sensitive_subfields_must_be_masked": true,
      "never_return_secret_material": true
    }
  },
  "acceptance_criteria": [
    {
      "id": "CR-001",
      "rule": "Credential references are opaque and pattern-constrained.",
      "testable_expression": "reference_object_contract.field_definitions.reference_id.pattern == '^cr_[a-z0-9]{12,64}$'"
    },
    {
      "id": "CR-002",
      "rule": "Secret material fields are globally forbidden.",
      "testable_expression": "contains(security_constraints.forbidden_fields_anywhere, 'raw_key_bytes') && contains(security_constraints.forbidden_fields_anywhere, 'plaintext_secret')"
    },
    {
      "id": "CR-003",
      "rule": "Resolution must pick one active version and preserve tenant consistency.",
      "testable_expression": "usage_contract.reference_resolution_rules.must_resolve_to_single_active_version == true && usage_contract.reference_resolution_rules.must_be_tenant_consistent == true"
    },
    {
      "id": "CR-004",
      "rule": "Rotation metadata and monotonic versions are mandatory.",
      "testable_expression": "rotation_contract.rotation_metadata_required == true && rotation_contract.version_monotonic_increase_required == true"
    },
    {
      "id": "CR-005",
      "rule": "API responses never return secret material.",
      "testable_expression": "security_constraints.api_response_policy.never_return_secret_material == true"
    }
  ],
  "non_goals": [
    "No provider-specific API commands, credentials, or environment configuration.",
    "No secret creation workflow implementation.",
    "No changes to validated bootstrap endpoint request/response contracts."
  ]
}
