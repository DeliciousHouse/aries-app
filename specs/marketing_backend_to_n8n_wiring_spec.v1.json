{
  "artifact_name": "marketing_backend_to_n8n_wiring_spec",
  "schema_version": "1.0.0",
  "api": {
    "post_jobs": {
      "route": "POST /api/marketing/jobs",
      "backend_handler": "./backend/marketing/jobs-start.ts#startMarketingJob",
      "n8n_target": "POST /webhook/marketing-research",
      "stage": "research"
    },
    "get_job_status": {
      "route": "GET /api/marketing/jobs/:jobId",
      "backend_handler": "./backend/marketing/jobs-status.ts#getMarketingJobStatus",
      "runtime_state_source": "./generated/draft/marketing-jobs/{job_id}.json"
    },
    "post_job_approve": {
      "route": "POST /api/marketing/jobs/:jobId/approve",
      "backend_handler": "./backend/marketing/jobs-approve.ts#approveMarketingJob",
      "n8n_target": "POST /webhook/marketing-approval-resume"
    }
  },
  "stage_flow": [
    "research",
    "approval_checkpoint",
    "strategy",
    "approval_checkpoint",
    "production",
    "approval_checkpoint",
    "publish"
  ],
  "invariants": [
    "job_id preserved across all stage transitions",
    "tenant_id preserved across all stage transitions",
    "structured status updates saved after each stage",
    "marketing-repair used only for bounded stage failures"
  ],
  "repair": {
    "workflow": "./n8n/marketing-repair.workflow.json",
    "max_attempts": 3,
    "scope": "failed stage section only"
  }
}
