{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specs/marketing_response_shapes.v1.json",
  "artifact_name": "marketing_response_shapes",
  "artifact_type": "json_schema_bundle",
  "schema_version": "1.0.0",
  "title": "Marketing API Response and Error Shapes (frozen from backend behavior)",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "StartJobAccepted": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marketing_job_status",
        "jobId",
        "tenantId",
        "jobType",
        "wiring",
        "runtimePath"
      ],
      "properties": {
        "jobId": {
          "type": "string",
          "minLength": 1
        },
        "tenantId": {
          "type": "string",
          "minLength": 1
        },
        "jobType": {
          "$ref": "#/$defs/MarketingJobType"
        },
        "wiring": {
          "type": "string",
          "enum": [
            "openclaw_gateway"
          ]
        },
        "runtimePath": {
          "type": "string",
          "minLength": 1
        },
        "marketing_job_status": {
          "const": "accepted"
        }
      }
    },
    "GetJobStatusResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jobId",
        "tenantId",
        "marketing_job_state",
        "marketing_job_status",
        "marketing_stage",
        "marketing_stage_status",
        "updatedAt",
        "runtimePath"
      ],
      "properties": {
        "jobId": {
          "type": "string",
          "minLength": 1
        },
        "tenantId": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtimePath": {
          "type": "string",
          "minLength": 1
        },
        "marketing_job_state": {
          "type": "string"
        },
        "marketing_job_status": {
          "type": "string"
        },
        "marketing_stage": {
          "type": [
            "string",
            "null"
          ]
        },
        "marketing_stage_status": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "ApproveJobResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_status",
        "jobId",
        "tenantId",
        "resumedStage",
        "completed",
        "wiring"
      ],
      "properties": {
        "jobId": {
          "type": "string",
          "minLength": 1
        },
        "tenantId": {
          "type": "string",
          "minLength": 1
        },
        "resumedStage": {
          "type": [
            "string",
            "null"
          ]
        },
        "completed": {
          "type": "boolean"
        },
        "wiring": {
          "type": "string",
          "enum": [
            "openclaw_gateway"
          ]
        },
        "approval_status": {
          "type": "string",
          "enum": [
            "resumed",
            "error"
          ]
        }
      }
    },
    "HardFailureError": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string",
          "pattern": "^HARD_FAILURE:"
        }
      },
      "description": "Thrown when required schemas are missing/invalid: ./specs/tenant_runtime_state_schema.v1.json or ./specs/job_runtime_state_schema.v1.json"
    },
    "UnhandledError": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string",
          "minLength": 1
        }
      },
      "description": "Catch-all for JSON parse failures, IO failures, and unexpected runtime exceptions"
    },
    "MarketingJobType": {
      "type": "string",
      "enum": [
        "marketing_research",
        "marketing_strategy",
        "marketing_production",
        "marketing_publish",
        "unknown"
      ]
    },
    "marketing_stage": {
      "type": "string",
      "enum": [
        "research",
        "strategy",
        "production",
        "publish"
      ]
    }
  }
}
