{
  "artifact_name": "marketing_approval_resume_workflow",
  "artifact_type": "n8n_workflow_spec",
  "schema_version": "1.0.0",
  "target": "self-hosted-n8n",
  "workflow_file": "./n8n/marketing-approval-resume.workflow.json",
  "trigger": {
    "type": "webhook",
    "path": "marketing-approval-resume",
    "method": "POST",
    "response_mode": "responseNode"
  },
  "inputs": [
    "job_id",
    "approval"
  ],
  "shared_schemas": [
    "./specs/job_runtime_state_schema.v1.json"
  ],
  "steps": [
    "normalize_input",
    "validate_required_input",
    "resume_paused_stages_with_stage_transitions",
    "persist_structured_status_updates",
    "respond_structured_json"
  ],
  "stage_model": {
    "ordered_stages": [
      "research",
      "strategy",
      "production",
      "publish"
    ],
    "resume_rule": "Only paused/waiting_approval/blocked stages can be resumed to queued after explicit approval. publish may be queued when resume_publish_if_needed=true and upstream stages are completed."
  },
  "bounded_repair_policy": {
    "scope": "stage_status fields only",
    "rules": [
      "If stage status is missing, initialize to paused for deterministic resume logic.",
      "If stage status is non-string or unknown, coerce to paused and record repair item.",
      "Do not mutate unrelated job fields."
    ]
  },
  "outputs": {
    "success_fields": [
      "status",
      "job_id",
      "tenant_id",
      "decision",
      "resumed_stages",
      "stage_transitions",
      "repairs",
      "job_runtime_path"
    ],
    "error_fields": [
      "status",
      "reason",
      "code",
      "details"
    ]
  },
  "allowed_node_types_reference": "./skills/n8n-local-runtime/contract.json"
}
