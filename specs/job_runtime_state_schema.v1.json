{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aries-platform-bootstrap/specs/job_runtime_state_schema.v1.json",
  "title": "job_runtime_state_schema.v1",
  "description": "Runtime state for an individual job executed in tenant provisioning and repair flows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "job_id",
    "job_type",
    "status",
    "attempt",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_name": {
      "const": "job_runtime_state_schema"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "$ref": "#/$defs/job_id"
    },
    "job_type": {
      "type": "string",
      "enum": [
        "tenant_provisioning",
        "tenant_repair",
        "validator",
        "publish",
        "unknown"
      ]
    },
    "tenant_id": {
      "$ref": "#/$defs/tenant_id"
    },
    "tenant_type": {
      "$ref": "#/$defs/tenant_type"
    },
    "signup_event_id": {
      "$ref": "#/$defs/idempotency_key"
    },
    "state": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "waiting_repair",
        "retrying",
        "completed",
        "failed",
        "canceled"
      ]
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "attempt": {
      "$ref": "#/$defs/attempt"
    },
    "max_attempts": {
      "$ref": "#/$defs/attempt"
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "api_request",
            "workflow",
            "manual",
            "scheduled",
            "unknown"
          ]
        },
        "path": {
          "type": "string"
        },
        "method": {
          "type": "string"
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "passed_checks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "failed_checks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "defects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/defect"
          },
          "default": []
        }
      }
    },
    "last_error": {
      "$ref": "#/$defs/error_info"
    },
    "related_jobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/job_ref"
      },
      "default": []
    },
    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/state_event"
      },
      "default": []
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "#/$defs/timestamp"
    }
  },
  "$defs": {
    "tenant_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,61}$"
    },
    "tenant_type": {
      "type": "string",
      "enum": [
        "single_user",
        "team"
      ]
    },
    "job_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{1,127}$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "pass",
        "fail",
        "error",
        "skipped"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "job_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "job_type",
        "status"
      ],
      "properties": {
        "job_id": {
          "$ref": "#/$defs/job_id"
        },
        "job_type": {
          "type": "string",
          "enum": [
            "tenant_provisioning",
            "tenant_repair",
            "validator",
            "publish",
            "unknown"
          ]
        },
        "status": {
          "$ref": "#/$defs/status"
        }
      }
    },
    "error_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "defect": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "check": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "state_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "at",
        "state",
        "status"
      ],
      "properties": {
        "at": {
          "$ref": "#/$defs/timestamp"
        },
        "state": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      },
      "default": {}
    }
  }
}
