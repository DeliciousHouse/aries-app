{
  "artifact_name": "n8n_tenant_repair_workflow",
  "artifact_type": "workflow_spec",
  "schema_version": "1.0.0",
  "target": "self-hosted-n8n",
  "workflow_file": "./n8n/tenant-repair.workflow.json",
  "trigger": {
    "type": "webhook",
    "path": "tenant-repair",
    "method": "POST"
  },
  "inputs": ["artifact_path", "defect_report", "attempt"],
  "repair": {
    "invoke_openclaw": true,
    "max_attempts": 3,
    "rerun_validator_each_attempt": true
  },
  "steps": [
    "normalize_input",
    "invoke_openclaw_repair_step",
    "run_validator",
    "branch_on_pass_fail",
    "retry_until_max_3",
    "respond_structured_json"
  ],
  "outputs": {
    "pass_fields": ["status", "artifact_path", "attempt", "validation_status"],
    "fail_fields": ["status", "artifact_path", "attempt", "validation_status", "max_attempts_reached"]
  }
}
