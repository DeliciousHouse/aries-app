{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tenant_admin_ui_contract.v1",
  "contract_name": "tenant_admin_ui_contract",
  "schema_version": "1.0.0",
  "scope": "Tenant administration UI surface contract limited to user access and tenant settings management.",
  "non_goals": [
    "No billing, analytics, or unrelated workspace feature definitions",
    "No visual layout implementation",
    "No backend implementation details"
  ],
  "shared_enums": {
    "tenant_admin_surface_state": [
      "idle",
      "loading",
      "ready",
      "saving",
      "error"
    ],
    "tenant_role": [
      "tenant_admin",
      "tenant_analyst",
      "tenant_viewer"
    ],
    "tenant_admin_error_code": [
      "forbidden",
      "not_found",
      "validation_failed",
      "conflict",
      "service_unavailable",
      "unknown"
    ]
  },
  "screens": [
    {
      "screen_id": "tenant_admin.members",
      "route": "/tenant-admin/members",
      "purpose": "List and manage tenant member roles.",
      "load_response_contract": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "tenant_id",
          "members"
        ],
        "properties": {
          "status": {
            "const": "ok"
          },
          "tenant_id": {
            "type": "string",
            "minLength": 1
          },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "user_id",
                "email",
                "role",
                "status"
              ],
              "properties": {
                "user_id": {
                  "type": "string",
                  "minLength": 1
                },
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "role": {
                  "enum": [
                    "tenant_admin",
                    "tenant_analyst",
                    "tenant_viewer"
                  ]
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "active",
                    "invited",
                    "suspended"
                  ]
                }
              }
            }
          }
        }
      },
      "mutations": [
        {
          "action_id": "tenant_admin.members.invite",
          "request_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "email",
              "role"
            ],
            "properties": {
              "email": {
                "type": "string",
                "format": "email"
              },
              "role": {
                "enum": [
                  "tenant_admin",
                  "tenant_analyst",
                  "tenant_viewer"
                ]
              }
            }
          },
          "success_response_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "invitation_id"
            ],
            "properties": {
              "status": {
                "const": "ok"
              },
              "invitation_id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "api_binding": {
            "operation_id": "tenantAdminInviteMember",
            "method": "POST",
            "path": "/api/tenant-admin/members/invite"
          }
        },
        {
          "action_id": "tenant_admin.members.update_role",
          "request_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "user_id",
              "role"
            ],
            "properties": {
              "user_id": {
                "type": "string",
                "minLength": 1
              },
              "role": {
                "enum": [
                  "tenant_admin",
                  "tenant_analyst",
                  "tenant_viewer"
                ]
              }
            }
          },
          "success_response_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "user_id",
              "role"
            ],
            "properties": {
              "status": {
                "const": "ok"
              },
              "user_id": {
                "type": "string",
                "minLength": 1
              },
              "role": {
                "enum": [
                  "tenant_admin",
                  "tenant_analyst",
                  "tenant_viewer"
                ]
              }
            }
          },
          "api_binding": {
            "operation_id": "tenantAdminUpdateMemberRole",
            "method": "PATCH",
            "path": "/api/tenant-admin/members/role"
          }
        }
      ]
    },
    {
      "screen_id": "tenant_admin.settings",
      "route": "/tenant-admin/settings",
      "purpose": "View and update core tenant profile/settings metadata.",
      "load_response_contract": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "tenant"
        ],
        "properties": {
          "status": {
            "const": "ok"
          },
          "tenant": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tenant_id",
              "display_name",
              "support_email",
              "time_zone"
            ],
            "properties": {
              "tenant_id": {
                "type": "string",
                "minLength": 1
              },
              "display_name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              "support_email": {
                "type": "string",
                "format": "email"
              },
              "time_zone": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      },
      "mutations": [
        {
          "action_id": "tenant_admin.settings.update_profile",
          "request_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "display_name",
              "support_email",
              "time_zone"
            ],
            "properties": {
              "display_name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              "support_email": {
                "type": "string",
                "format": "email"
              },
              "time_zone": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "success_response_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "tenant"
            ],
            "properties": {
              "status": {
                "const": "ok"
              },
              "tenant": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "tenant_id",
                  "display_name",
                  "support_email",
                  "time_zone"
                ],
                "properties": {
                  "tenant_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "display_name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 120
                  },
                  "support_email": {
                    "type": "string",
                    "format": "email"
                  },
                  "time_zone": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          },
          "api_binding": {
            "operation_id": "tenantAdminUpdateSettings",
            "method": "PATCH",
            "path": "/api/tenant-admin/settings"
          }
        }
      ]
    }
  ],
  "error_contract": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "status",
      "error"
    ],
    "properties": {
      "status": {
        "const": "error"
      },
      "error": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "enum": [
              "forbidden",
              "not_found",
              "validation_failed",
              "conflict",
              "service_unavailable",
              "unknown"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "field_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "field",
                "reason"
              ],
              "properties": {
                "field": {
                  "type": "string",
                  "minLength": 1
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
