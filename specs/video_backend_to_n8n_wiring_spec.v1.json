{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video_backend_to_n8n_wiring_spec.v1.json",
  "title": "Video Backend to n8n Wiring Spec v1",
  "description": "Machine-checkable integration wiring between backend events and n8n workflow trigger/update endpoints for the Veo parallel lane.",
  "type": "object",
  "required": [
    "schema_version",
    "integration",
    "backend_emit",
    "n8n_ingress",
    "ack_contract",
    "retry_policy",
    "field_mapping"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "integration": {
      "type": "string",
      "const": "video_backend_to_n8n"
    },
    "backend_emit": {
      "$ref": "#/$defs/backendEmitContract"
    },
    "n8n_ingress": {
      "$ref": "#/$defs/n8nIngressContract"
    },
    "ack_contract": {
      "$ref": "#/$defs/ackContract"
    },
    "retry_policy": {
      "$ref": "#/$defs/retryPolicy"
    },
    "field_mapping": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/fieldMap"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "backendEmitContract": {
      "type": "object",
      "required": [
        "transport",
        "event_types",
        "signature_header",
        "content_type"
      ],
      "properties": {
        "transport": {
          "type": "string",
          "const": "https_webhook"
        },
        "event_types": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "enum": [
              "video_job.accepted",
              "video_job.progress",
              "video_job.completed",
              "video_job.failed",
              "video_job.cancelled"
            ]
          },
          "uniqueItems": true
        },
        "signature_header": {
          "type": "string",
          "const": "x-signature-sha256"
        },
        "idempotency_header": {
          "type": "string",
          "const": "idempotency-key"
        },
        "content_type": {
          "type": "string",
          "const": "application/json"
        }
      },
      "additionalProperties": false
    },
    "n8nIngressContract": {
      "type": "object",
      "required": [
        "workflow_id",
        "method",
        "path",
        "auth",
        "request_shape"
      ],
      "properties": {
        "workflow_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "method": {
          "type": "string",
          "const": "POST"
        },
        "path": {
          "type": "string",
          "pattern": "^/webhook/[a-zA-Z0-9._-]+$"
        },
        "auth": {
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "hmac_sha256",
                "basic",
                "none"
              ]
            },
            "secret_ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            }
          },
          "additionalProperties": false
        },
        "request_shape": {
          "type": "string",
          "const": "video_job_event.v1"
        }
      },
      "additionalProperties": false
    },
    "ackContract": {
      "type": "object",
      "required": [
        "success_http_status",
        "max_ack_ms",
        "body"
      ],
      "properties": {
        "success_http_status": {
          "type": "integer",
          "enum": [
            200,
            202,
            204
          ]
        },
        "max_ack_ms": {
          "type": "integer",
          "minimum": 50,
          "maximum": 30000,
          "default": 5000
        },
        "body": {
          "type": "object",
          "required": [
            "accepted",
            "received_at"
          ],
          "properties": {
            "accepted": {
              "type": "boolean"
            },
            "received_at": {
              "type": "string",
              "format": "date-time"
            },
            "reason": {
              "type": "string",
              "maxLength": 256
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "retryPolicy": {
      "type": "object",
      "required": [
        "strategy",
        "max_attempts",
        "base_delay_ms",
        "max_delay_ms",
        "retry_on_status"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "const": "exponential_backoff_with_jitter"
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "base_delay_ms": {
          "type": "integer",
          "minimum": 50,
          "maximum": 60000
        },
        "max_delay_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 300000
        },
        "retry_on_status": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 400,
            "maximum": 599
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "fieldMap": {
      "type": "object",
      "required": [
        "from",
        "to",
        "required",
        "type"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "to": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "required": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "integer",
            "number",
            "boolean",
            "object",
            "array"
          ]
        },
        "transform": {
          "type": "string",
          "enum": [
            "none",
            "to_string",
            "to_number",
            "iso_datetime",
            "pass_through"
          ],
          "default": "none"
        }
      },
      "additionalProperties": false
    }
  }
}
