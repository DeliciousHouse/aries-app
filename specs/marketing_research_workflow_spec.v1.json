{
  "artifact_name": "marketing_research_workflow",
  "artifact_type": "n8n_workflow_spec",
  "schema_version": "1.0.0",
  "target": "self-hosted-n8n",
  "workflow_file": "./n8n/marketing-research.workflow.json",
  "trigger": {
    "type": "webhook",
    "path": "marketing-research",
    "method": "POST",
    "response_mode": "responseNode"
  },
  "inputs": [
    "tenant_id",
    "job_type",
    "request"
  ],
  "shared_schemas": [
    "./specs/tenant_runtime_state_schema.v1.json",
    "./specs/job_runtime_state_schema.v1.json"
  ],
  "steps": [
    "normalize_input",
    "validate_required_input",
    "assert_shared_schemas_exist_and_parse",
    "create_marketing_job_runtime_record",
    "respond_structured_json"
  ],
  "outputs": {
    "success_fields": [
      "status",
      "tenant_id",
      "job_type",
      "job_id",
      "job_state",
      "job_runtime_path"
    ],
    "error_fields": [
      "status",
      "reason",
      "code",
      "required"
    ]
  },
  "allowed_node_types_reference": "./skills/n8n-local-runtime/contract.json"
}
