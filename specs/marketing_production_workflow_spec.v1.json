{
  "artifact_name": "marketing_production_workflow",
  "artifact_type": "n8n_workflow_spec",
  "schema_version": "1.0.0",
  "target": "self-hosted-n8n",
  "workflow_file": "./n8n/marketing-production.workflow.json",
  "trigger": {
    "type": "webhook",
    "path": "marketing-production",
    "method": "POST",
    "response_mode": "responseNode"
  },
  "inputs": [
    "tenant_id",
    "job_type",
    "request"
  ],
  "consumes_strategy_outputs": [
    "request.strategy_outputs",
    "request.strategy"
  ],
  "shared_schemas": [
    "./specs/tenant_runtime_state_schema.v1.json",
    "./specs/job_runtime_state_schema.v1.json"
  ],
  "steps": [
    "normalize_input",
    "validate_required_input",
    "assert_shared_schemas_exist_and_parse",
    "create_production_job_runtime_record",
    "approval_checkpoint_before_publish",
    "publish_with_bounded_repair_when_approved",
    "respond_structured_json"
  ],
  "production_parallelization": {
    "logical_branches": [
      "ad-designer",
      "scriptwriter",
      "page-designer"
    ],
    "execution_note": "Branches are represented as structured branch status objects produced in one deterministic orchestration step."
  },
  "job_state_transitions": [
    "queued",
    "running",
    "production_parallelized",
    "awaiting_approval",
    "publishing",
    "repair_running",
    "completed",
    "failed"
  ],
  "structured_status_updates": {
    "field": "status_updates",
    "item_shape": [
      "at",
      "state",
      "status",
      "step",
      "details"
    ]
  },
  "outputs": {
    "success_fields": [
      "status",
      "tenant_id",
      "job_type",
      "job_id",
      "job_state",
      "approval_required",
      "published",
      "repair_attempted",
      "job_runtime_path",
      "status_updates"
    ],
    "error_fields": [
      "status",
      "reason",
      "code",
      "required"
    ]
  },
  "allowed_node_types_reference": "./skills/n8n-local-runtime/contract.json"
}
