{
  "artifact_name": "marketing_strategy_workflow",
  "artifact_type": "n8n_workflow_spec",
  "schema_version": "1.0.0",
  "target": "self-hosted-n8n",
  "workflow_file": "./n8n/marketing-strategy.workflow.json",
  "trigger": {
    "type": "webhook",
    "path": "marketing-strategy",
    "method": "POST",
    "response_mode": "responseNode"
  },
  "inputs": [
    "tenant_id",
    "job_type",
    "request"
  ],
  "shared_schemas": [
    "./specs/tenant_runtime_state_schema.v1.json",
    "./specs/job_runtime_state_schema.v1.json"
  ],
  "approval_gate": {
    "required_before_production": true,
    "checkpoint_field": "request.approval.approved",
    "behavior_when_not_approved": "return_awaiting_approval_and_hold_running_state"
  },
  "repair": {
    "bounded": true,
    "max_attempts": 3,
    "trigger_conditions": [
      "research_artifact_missing",
      "research_artifact_empty"
    ],
    "behavior_after_limit": "mark_failed_and_return_repair_limit_reached"
  },
  "steps": [
    "normalize_input",
    "validate_required_input",
    "assert_shared_schemas_exist_and_parse",
    "build_strategy_job_and_stage_transitions",
    "route_structured_status_response"
  ],
  "outputs": {
    "success_fields": [
      "status",
      "tenant_id",
      "job_type",
      "job_id",
      "job_state",
      "current_stage",
      "approval_checkpoint",
      "structured_status_updates",
      "job_runtime_path"
    ],
    "error_fields": [
      "status",
      "reason",
      "code",
      "required"
    ]
  },
  "allowed_node_types_reference": "./skills/n8n-local-runtime/contract.json"
}
