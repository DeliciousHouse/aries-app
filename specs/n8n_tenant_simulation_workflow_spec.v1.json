{
  "artifact_name": "n8n_tenant_simulation_workflow",
  "artifact_type": "workflow_spec",
  "schema_version": "1.0.0",
  "target": "self-hosted-n8n",
  "workflow_file": "./n8n/tenant-simulation.workflow.json",
  "simulation": {
    "tenant_id": "acme-sim",
    "tenant_type": "single_user",
    "same_signup_event_id_twice": true
  },
  "steps": [
    "create_simulated_signup_payload",
    "invoke_provisioning_run_1",
    "invoke_provisioning_run_2_same_idempotency_key",
    "confirm_no_duplicate_workspace",
    "save_simulation_results"
  ],
  "outputs": {
    "result_file": "./generated/draft/simulation-result.json",
    "required_fields": ["tenant_id", "signup_event_id", "workspace_count", "duplicate_prevented", "first_run", "second_run"]
  }
}
