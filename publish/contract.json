{
  "name": "n8n-publish-subsystem",
  "version": "1.0.0",
  "baseUrlEnv": "N8N_BASE_URL",
  "apiKeyEnv": "N8N_API_KEY",
  "codeRootEnv": "CODE_ROOT",
  "dataRootEnv": "DATA_ROOT",
  "workflowDir": "/app/n8n",
  "rawResponseOutput": "/data/generated/draft/n8n-publish-results.json",
  "phaseLogOutput": "/data/generated/draft/n8n-publish-phase-log.md",
  "defectReportOutput": "/data/generated/draft/n8n-publish-defect-report.json",
  "maxRepairAttempts": 3,
  "sectionOnlyRepair": true,
  "constraints": {
    "doNotRedesignValidatedArtifacts": true,
    "doNotRedesignWorkingWorkflowLogicUnlessApiProvesInvalid": true,
    "patchOnlyFailingSection": true,
    "saveRawApiResponses": true
  },
  "allowedNodeTypes": [
    "n8n-nodes-base.webhook",
    "n8n-nodes-base.set",
    "n8n-nodes-base.if",
    "n8n-nodes-base.executeCommand",
    "n8n-nodes-base.httpRequest",
    "n8n-nodes-base.respondToWebhook"
  ],
  "endpoints": {
    "createWorkflow": "POST /api/v1/workflows",
    "updateWorkflow": "PUT /api/v1/workflows/:id",
    "activateWorkflow": "POST /api/v1/workflows/:id/activate"
  }
}
