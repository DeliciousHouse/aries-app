{
  "name": "n8n-publish-subsystem",
  "version": "1.0.0",
  "baseUrlEnv": "N8N_BASE_URL",
  "apiKeyEnv": "N8N_API_KEY",
  "projectRootEnv": "PROJECT_ROOT",
  "workflowDir": "./n8n",
  "rawResponseOutput": "./generated/draft/n8n-publish-results.json",
  "phaseLogOutput": "./generated/draft/n8n-publish-phase-log.md",
  "defectReportOutput": "./generated/draft/n8n-publish-defect-report.json",
  "maxRepairAttempts": 3,
  "sectionOnlyRepair": true,
  "constraints": {
    "doNotRedesignValidatedArtifacts": true,
    "doNotRedesignWorkingWorkflowLogicUnlessApiProvesInvalid": true,
    "patchOnlyFailingSection": true,
    "saveRawApiResponses": true
  },
  "allowedNodeTypes": [
    "n8n-nodes-base.webhook",
    "n8n-nodes-base.set",
    "n8n-nodes-base.if",
    "n8n-nodes-base.executeCommand",
    "n8n-nodes-base.httpRequest",
    "n8n-nodes-base.respondToWebhook"
  ],
  "endpoints": {
    "createWorkflow": "POST /rest/workflows",
    "updateWorkflow": "PATCH /rest/workflows/:id",
    "activateWorkflow": "PATCH /rest/workflows/:id"
  }
}
